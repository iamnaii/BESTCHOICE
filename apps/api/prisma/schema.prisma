  signerName     String?    @map("signer_name") // ชื่อผู้เซ็น
  ipAddress      String?    @map("ip_address")
  deviceInfo     String?    @map("device_info") // User-Agent
  screenSize     String?    @map("screen_size") // ขนาดหน้าจอ
