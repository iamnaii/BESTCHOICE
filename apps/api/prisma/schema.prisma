generator client {
  provider = "prisma-client-js"
}

// Cloud SQL (Cloud Run) connection format:
//   postgresql://USER:PASS@localhost/DB?host=/cloudsql/PROJECT:REGION:INSTANCE&connection_limit=10
// Local / TCP connection format:
//   postgresql://USER:PASS@HOST:5432/DB
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  SALES
  BRANCH_MANAGER
  ACCOUNTANT
  FINANCE_MANAGER
  OWNER
}

enum SupplierType {
  INDIVIDUAL
  JURISTIC
}

enum ContractStatus {
  DRAFT
  ACTIVE
  OVERDUE
  DEFAULT
  EARLY_PAYOFF
  COMPLETED
  EXCHANGED
  DEFECT_EXCHANGED
  CLOSED_BAD_DEBT
}

// Dunning escalation stages for overdue debt collection
enum TodoStatus {
  TODO
  DOING
  REVIEW
  DONE
}

enum TodoPriority {
  LOW
  MEDIUM
  HIGH
}

enum DunningStage {
  NONE // ปกติ ยังไม่ overdue
  REMINDER // แจ้งเตือน (1-7 วัน overdue)
  NOTICE // แจ้งค้างชำระ (8-30 วัน)
  FINAL_WARNING // เตือนครั้งสุดท้าย (31-60 วัน)
  LEGAL_ACTION // ดำเนินคดี/ยึดคืน (>60 วัน)
}

enum PlanType {
  STORE_DIRECT
  CREDIT_CARD
  STORE_WITH_INTEREST
}

enum ProductStatus {
  PO_RECEIVED
  QC_PENDING // รอตรวจสอบคุณภาพ (ก่อนเข้าคลัง)
  PHOTO_PENDING // รอถ่ายรูปสินค้า 6 มุม (หลัง QC ผ่าน)
  INSPECTION
  IN_STOCK
  RESERVED
  SOLD_INSTALLMENT
  SOLD_CASH
  REPOSSESSED
  REFURBISHED
  SOLD_RESELL
  DAMAGED
  DEFECT_RETURN
  LOST
  WRITTEN_OFF
}

enum ProductCategory {
  PHONE_NEW
  PHONE_USED
  TABLET
  ACCESSORY
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  QR_EWALLET
  CREDIT_BALANCE
  ONLINE_GATEWAY
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIALLY_PAID
  OVERDUE
}

enum POStatus {
  DRAFT
  APPROVED
  PENDING
  PARTIALLY_RECEIVED
  FULLY_RECEIVED
  CANCELLED
}

enum POPaymentStatus {
  UNPAID
  DEPOSIT_PAID
  PARTIALLY_PAID
  FULLY_PAID
}

enum ReceivingItemStatus {
  PASS
  REJECT
}

enum TransferStatus {
  PENDING
  IN_TRANSIT // กำลังจัดส่ง
  CONFIRMED
  REJECTED
}

enum InspectionScoreType {
  PASS_FAIL
  GRADE
  SCORE_1_5
  NUMBER
}

enum ConditionGrade {
  A
  B
  C
  D
}

enum SignerType {
  CUSTOMER
  COMPANY // ผู้ขาย/ผู้ให้เช่าซื้อ (พนักงาน)
  WITNESS_1 // พยานคนที่ 1
  WITNESS_2 // พยานคนที่ 2
  GUARDIAN // ผู้ปกครอง (อายุ 17-19)
  STAFF     @map("STAFF") // legacy alias
}

enum ConsentStatus {
  PENDING
  GRANTED
  REVOKED
}

enum DSARRequestType {
  ACCESS // สิทธิ์เข้าถึง
  RECTIFICATION // สิทธิ์แก้ไข
  DELETION // สิทธิ์ลบ
  DATA_PORTABILITY // สิทธิ์โอนข้อมูล
  OBJECTION // สิทธิ์คัดค้าน
}

enum DSARStatus {
  SUBMITTED
  IN_PROGRESS
  COMPLETED
  REJECTED
}

enum DocumentRetentionStatus {
  ACTIVE
  PENDING_DELETION
  LEGAL_HOLD
  DELETED
}

enum NotificationChannel {
  LINE
  SMS
  IN_APP
}

enum RepossessionStatus {
  REPOSSESSED
  UNDER_REPAIR
  READY_FOR_SALE
  SOLD
}

enum StockAdjustmentReason {
  DAMAGED
  LOST
  FOUND
  CORRECTION
  WRITE_OFF
  OTHER
}

enum SaleType {
  CASH
  INSTALLMENT
  EXTERNAL_FINANCE
}

enum InterCompanyTransactionType {
  FINANCE_PURCHASE // Finance ซื้อลูกหนี้จาก Shop (principal + commission)
  COMMISSION_PAYMENT // Finance จ่าย commission ให้ Shop
  LATE_FEE_SHARE // ส่วนแบ่งค่าปรับล่าช้า
}

enum InterCompanyTransactionStatus {
  PENDING
  CONFIRMED
  RECONCILED
  CANCELLED
}

enum ContractWorkflowStatus {
  CREATING // กำลังสร้าง
  PENDING_REVIEW // รอตรวจสอบ
  APPROVED // อนุมัติแล้ว
  REJECTED // ปฏิเสธ (ส่งกลับแก้ไข)
}

enum CreditCheckStatus {
  PENDING
  APPROVED
  REJECTED
  MANUAL_REVIEW
}

enum WhtIncomeType {
  SALARY_40_1 // เงินเดือน ม.40(1)
  HIRE_40_2 // ค่าจ้าง ม.40(2)
  ROYALTY_40_3 // ค่าลิขสิทธิ์ ม.40(3)
  INTEREST_40_4A // ดอกเบี้ย ม.40(4)(ก)
  DIVIDEND_40_4B // เงินปันผล ม.40(4)(ข)
  RENT_40_5 // ค่าเช่า ม.40(5)
  PROFESSION_40_6 // วิชาชีพอิสระ ม.40(6)
  CONTRACTOR_40_7 // รับเหมา ม.40(7)
  OTHER_40_8 // อื่นๆ ม.40(8)
}

enum TaxReportType {
  PP30 // ภ.พ.30 (VAT รายเดือน)
  PND3 // ภ.ง.ด.3 (หัก ณ ที่จ่าย บุคคล)
  PND53 // ภ.ง.ด.53 (หัก ณ ที่จ่าย นิติบุคคล)
}

enum TaxReportStatus {
  DRAFT
  SUBMITTED
  FILED
}

enum AccountingPeriodStatus {
  OPEN
  REVIEW
  CLOSED
  SYNCED
}

enum ContractDocumentType {
  SIGNED_CONTRACT
  ID_CARD_COPY
  ID_CARD_BACK
  KYC_SELFIE // รูปถ่ายลูกค้าถือบัตรประชาชน
  DEVICE_PHOTO // รูปถ่ายสินค้า+IMEI
  DEVICE_IMEI_PHOTO // รูปหน้าจอแสดง IMEI
  DOWN_PAYMENT_RECEIPT // หลักฐานการชำระเงินดาวน์
  PDPA_CONSENT // เอกสาร Consent PDPA
  GUARDIAN_DOC // เอกสารผู้ปกครอง (อายุ 17-19)
  PAYMENT_SCHEDULE // ตารางผ่อนชำระ
  PAYMENT_RECEIPT // ใบเสร็จรับเงิน
  ADDENDUM // สัญญาแก้ไขเพิ่มเติม
  FACEBOOK_PROFILE
  FACEBOOK_POST
  LINE_PROFILE
  DEVICE_RECEIPT_PHOTO
  BANK_STATEMENT
  KYC // legacy
  OTHER
}

enum DunningChannel {
  LINE
  SMS
  CALL_TASK
  INTERNAL_ALERT
}

enum DunningActionStatus {
  PENDING
  SENT
  DELIVERED
  FAILED
  SKIPPED
}

// ============================================================
// CORE ENTITIES
// ============================================================

model Branch {
  id        String   @id @default(uuid())
  name      String
  location  String?
  phone     String?
  companyId String?  @map("company_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  isMainWarehouse Boolean   @default(false) @map("is_main_warehouse")
  deletedAt       DateTime? @map("deleted_at")

  company                  CompanyInfo?              @relation(fields: [companyId], references: [id])
  users                    User[]
  products                 Product[]
  contracts                Contract[]
  sales                    Sale[]
  stockFroms               StockTransfer[]           @relation("TransferFrom")
  stockTos                 StockTransfer[]           @relation("TransferTo")
  stockAdjustments         StockAdjustment[]
  reorderPoints            ReorderPoint[]
  stockAlerts              StockAlert[]
  stockCounts              StockCount[]
  inviteTokens             InviteToken[]
  financeReceivables       FinanceReceivable[]
  expenses                 Expense[]
  interCompanyTransactions InterCompanyTransaction[]
  fixedAssets              FixedAsset[]
  tradeIns                 TradeIn[]
  crmLeads                 CrmLead[]

  @@index([companyId])
  @@map("branches")
}

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  password         String
  name             String
  role             UserRole  @default(SALES)
  branchId         String?   @map("branch_id")
  isActive         Boolean   @default(true) @map("is_active")
  savedSignature   String?   @map("saved_signature") @db.Text
  employeeId       String?   @unique @map("employee_id")
  nickname         String?   @map("nickname")
  phone            String?   @map("phone")
  lineId           String?   @map("line_id")
  address          String?   @map("address") @db.Text
  avatarUrl        String?   @map("avatar_url") @db.Text
  startDate        DateTime? @map("start_date")
  nationalId       String?   @map("national_id")
  birthDate        DateTime? @map("birth_date")
  // Two-Factor Authentication (TOTP)
  twoFactorEnabled Boolean   @default(false) @map("two_factor_enabled")
  twoFactorSecret  String?   @map("two_factor_secret") // encrypted TOTP secret
  twoFactorBackup  String?   @map("two_factor_backup") // encrypted recovery codes (JSON)

  // Brute-force protection: incremented on failed login, reset on success.
  // When failedLoginAttempts >= LOCKOUT_THRESHOLD the account is locked
  // until lockedUntil. The lock auto-expires so admin doesn't have to
  // manually reset (admin can also clear by setting both to null).
  failedLoginAttempts Int       @default(0) @map("failed_login_attempts")
  lockedUntil         DateTime? @map("locked_until")
  lastLoginAt         DateTime? @map("last_login_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  branch Branch? @relation(fields: [branchId], references: [id])

  contractsAsSalesperson Contract[]           @relation("Salesperson")
  contractsReviewed      Contract[]           @relation("ContractReviewer")
  salesAsSalesperson     Sale[]               @relation("SalesSalesperson")
  paymentsRecorded       Payment[]            @relation("RecordedBy")
  inspections            Inspection[]
  callLogs               CallLog[]
  auditLogs              AuditLog[]
  purchaseOrdersCreated  PurchaseOrder[]      @relation("POCreatedBy")
  purchaseOrdersApproved PurchaseOrder[]      @relation("POApprovedBy")
  repossessionsAppraised Repossession[]       @relation("AppraisedBy")
  goodsReceivings        GoodsReceiving[]     @relation("GoodsReceivedBy")
  transfersConfirmed     StockTransfer[]      @relation("TransferConfirmedBy")
  transfersDispatched    StockTransfer[]      @relation("TransferDispatchedBy")
  stockAdjustments       StockAdjustment[]    @relation("StockAdjustedBy")
  stockAdjustmentsApproved StockAdjustment[] @relation("StockAdjustmentApprovedBy")
  documentsUploaded      ContractDocument[]   @relation("DocumentUploadedBy")
  creditChecks           CreditCheck[]        @relation("CreditCheckedBy")
  creditOverrides        CreditCheck[]        @relation("CreditOverriddenBy")
  branchReceivings       BranchReceiving[]    @relation("BranchReceivedBy")
  stockCounts            StockCount[]         @relation("StockCountedBy")
  productPhotosUploaded  ProductPhoto[]       @relation("ProductPhotoUploadedBy")
  refreshTokens          RefreshToken[]
  passwordResetTokens    PasswordResetToken[]
  reviewedEvidences      PaymentEvidence[]    @relation("EvidenceReviewedBy")
  inviteTokens           InviteToken[]
  financeRecorded        FinanceReceivable[]  @relation("FinanceRecordedBy")
  expensesCreated        Expense[]            @relation("ExpenseCreatedBy")
  expensesApproved       Expense[]            @relation("ExpenseApprovedBy")
  expensesVoided         Expense[]            @relation("ExpenseVoidedBy")
  journalEntriesCreated  JournalEntry[]       @relation("JournalCreatedBy")
  journalEntriesPosted   JournalEntry[]       @relation("JournalPostedBy")
  taxReportsFiled        TaxReport[]          @relation("TaxReportFiledBy")
  commissionsEarned      SalesCommission[]    @relation("CommissionSalesperson")
  commissionsApproved    SalesCommission[]    @relation("CommissionApprovedBy")
  contractsAssigned      Contract[]           @relation("ContractAssignedTo")
  payoutsEarned          CommissionPayout[]   @relation("PayoutSalesperson")
  payoutsApproved        CommissionPayout[]   @relation("PayoutApprovedBy")
  payoutsPaid            CommissionPayout[]   @relation("PayoutPaidBy")
  tradeInsAppraised      TradeIn[]            @relation("TradeInAppraisedBy")
  tradeInsIdVerified     TradeIn[]            @relation("TradeInIdCardVerifiedBy")
  assetsCreated          FixedAsset[]         @relation("AssetCreatedBy")
  todosCreated           Todo[]               @relation("TodoCreatedBy")
  todosAssigned          Todo[]               @relation("TodoAssignedTo")
  todoComments           TodoComment[]        @relation("TodoCommentUser")
  handoffRooms           ChatRoom[]           @relation("ChatHandoffStaff")
  assignedRooms          ChatRoom[]           @relation("ChatAssignedStaff")
  chatMessages           ChatMessage[]        @relation("ChatMessageStaff")
  staffChatActivities    StaffChatActivity[]  @relation("StaffChatActivityUser")
  chatNotes              ChatNote[]           @relation("ChatNoteStaff")
  kbSuggestionsReviewed  ChatKbSuggestion[]   @relation("KbSuggestionReviewer")
  webhookSubscriptions   WebhookSubscription[]
  crmLeadsAssigned       CrmLead[]            @relation("CrmLeadAssignedTo")
  crmNotes               CrmNote[]            @relation("CrmNoteStaff")
  chatSnoozes            ChatSnooze[]         @relation("ChatSnoozeStaff")
  chatSideMessages       ChatSideMessage[]    @relation("ChatSideMessageStaff")
  dunningActionsExecuted DunningAction[]      @relation("DunningActionExecutor")
  periodsReviewStarted   AccountingPeriod[]   @relation("PeriodReviewStartedBy")
  periodsClosed          AccountingPeriod[]   @relation("PeriodClosedBy")
  broadcastMessages      BroadcastMessage[]   @relation("BroadcastCreatedBy")
  broadcastsApproved     BroadcastMessage[]   @relation("BroadcastApprovedBy")
  broadcastsRejected     BroadcastMessage[]   @relation("BroadcastRejectedBy")

  @@index([branchId])
  @@map("users")
}

model Customer {
  id                 String    @id @default(uuid())
  nationalId         String    @unique @map("national_id") // encrypted AES-256
  prefix             String? // คำนำหน้า (นาย, นาง, นางสาว)
  name               String
  nickname           String? // ชื่อเล่น
  isForeigner        Boolean   @default(false) @map("is_foreigner") // ต่างด้าว
  birthDate          DateTime? @map("birth_date") // วันเกิด
  phone              String
  phoneSecondary     String?   @map("phone_secondary")
  email              String? // อีเมล
  lineId             String?   @map("line_id")
  facebookLink       String?   @map("facebook_link") // ลิงก์ Facebook
  facebookName       String?   @map("facebook_name") // ชื่อ Facebook
  facebookFriends    String?   @map("facebook_friends") // จำนวนเพื่อน Facebook
  googleMapLink      String?   @map("google_map_link") // Link Google Map
  addressIdCard      String?   @map("address_id_card")
  addressCurrent     String?   @map("address_current")
  addressCurrentType String?   @map("address_current_type") // บ้านตัวเอง, บ้านญาติ, เช่าอาศัย
  salaryPayDay       Int?      @map("salary_pay_day") // วันที่เงินเดือนออก (1-31)
  occupation         String?
  occupationDetail   String?   @map("occupation_detail") // รายละเอียดอาชีพ
  salary             Decimal?  @db.Decimal(12, 2) // เงินเดือน
  workplace          String?
  addressWork        String?   @map("address_work") // ที่อยู่ที่ทำงาน
  references         Json? // บุคคลอ้างอิง [{prefix, firstName, lastName, phone, relationship}]
  documents          String[]  @default([]) // array of file URLs

  // Guardian (ผู้ปกครอง) — สำหรับลูกค้าอายุ 17-19
  guardianName       String? @map("guardian_name")
  guardianNationalId String? @map("guardian_national_id")
  guardianPhone      String? @map("guardian_phone")
  guardianRelation   String? @map("guardian_relation")
  guardianAddress    String? @map("guardian_address")

  // Referral — ลูกค้าที่แนะนำมา
  referredById      String?    @map("referred_by_id")
  referredBy        Customer?  @relation("Referral", fields: [referredById], references: [id])
  referrals         Customer[] @relation("Referral")
  // Atomic idempotency marker for awardReferralPoints. Set inside the same
  // transaction that credits points to the referrer, so retries/races cannot
  // award twice. NULL = not yet awarded.
  referralAwardedAt DateTime?  @map("referral_awarded_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  loyaltyBalance Int @default(0) @map("loyalty_balance") // cached point balance

  // Legacy migration tracking (จากโปรแกรมเขียว)
  legacyMemberCode String? @unique @map("legacy_member_code")

  contracts          Contract[]
  sales              Sale[]
  creditChecks       CreditCheck[]
  pdpaConsents       PDPAConsent[]
  dsarRequests       DSARRequest[]
  kycVerifications   KycVerification[]
  loyaltyPoints      LoyaltyPoint[]
  loyaltyRedemptions LoyaltyRedemption[]
  tradeIns           TradeIn[]
  promotionUsages    PromotionUsage[]

  // Multi-channel LINE binding (chatbot-finance)
  lineLinks        CustomerLineLink[]
  chatRooms        ChatRoom[]
  chatAutoTriggers ChatAutoTrigger[]
  chatConsent      Boolean            @default(false) @map("chat_consent")
  chatConsentAt    DateTime?          @map("chat_consent_at")

  // LINE notification preferences
  notifPaymentReminder Boolean @default(true) @map("notif_payment_reminder")
  notifOverdueNotice   Boolean @default(true) @map("notif_overdue_notice")
  notifReceipt         Boolean @default(true) @map("notif_receipt")

  // Ads + CRM
  adsAttributions  AdsAttribution[]
  crmLeads         CrmLead[]
  customerScore    CustomerScore?

  @@index([phone])
  @@index([name])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([referredById])
  @@map("customers")
}

model Contract {
  id               String         @id @default(uuid())
  contractNumber   String         @unique @map("contract_number")
  customerId       String         @map("customer_id")
  productId        String         @map("product_id")
  branchId         String         @map("branch_id")
  salespersonId    String         @map("salesperson_id")
  planType         PlanType       @map("plan_type")
  sellingPrice     Decimal        @map("selling_price") @db.Decimal(12, 2)
  downPayment      Decimal        @map("down_payment") @db.Decimal(12, 2)
  interestRate     Decimal        @map("interest_rate") @db.Decimal(5, 4) // e.g. 0.0800
  totalMonths      Int            @map("total_months")
  interestTotal    Decimal        @map("interest_total") @db.Decimal(12, 2)
  financedAmount   Decimal        @map("financed_amount") @db.Decimal(12, 2)
  storeCommission  Decimal?       @map("store_commission") @db.Decimal(12, 2)
  vatAmount        Decimal?       @map("vat_amount") @db.Decimal(12, 2)
  vatPct           Decimal?       @map("vat_pct") @db.Decimal(5, 4)
  monthlyPayment   Decimal        @map("monthly_payment") @db.Decimal(12, 2)
  status           ContractStatus @default(DRAFT)
  parentContractId String?        @map("parent_contract_id")
  notes            String?
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  deletedAt        DateTime?      @map("deleted_at")

  // Workflow: สองฝ่าย (ทำสัญญา vs ตรวจสอบ)
  workflowStatus ContractWorkflowStatus @default(CREATING) @map("workflow_status")
  reviewedById   String?                @map("reviewed_by_id")
  reviewedAt     DateTime?              @map("reviewed_at")
  reviewNotes    String?                @map("review_notes")

  // วันที่ครบกำหนดชำระ ตามวันเงินเดือนออก (1-28)
  paymentDueDay Int? @map("payment_due_day")

  // ที่มาดอกเบี้ย
  interestConfigId String? @map("interest_config_id")

  customer       Customer        @relation(fields: [customerId], references: [id])
  product        Product         @relation(fields: [productId], references: [id])
  branch         Branch          @relation(fields: [branchId], references: [id])
  salesperson    User            @relation("Salesperson", fields: [salespersonId], references: [id])
  parentContract Contract?       @relation("ContractExchange", fields: [parentContractId], references: [id])
  childContracts Contract[]      @relation("ContractExchange")
  reviewedBy     User?           @relation("ContractReviewer", fields: [reviewedById], references: [id])
  interestConfig InterestConfig? @relation(fields: [interestConfigId], references: [id])

  // PDPA consent ที่ผูกกับสัญญานี้
  pdpaConsentId String? @unique @map("pdpa_consent_id")

  // Contract document hash (SHA-256) สำหรับ verify integrity
  contractHash String? @map("contract_hash")

  // Snapshot ข้อมูลลูกค้า ณ เวลาที่สร้างสัญญา (ป้องกันการเปลี่ยนย้อนหลัง)
  customerSnapshot Json? @map("customer_snapshot")

  // Legal clauses flags (ข้อความตามกฎหมาย)
  hasOwnershipClause    Boolean @default(false) @map("has_ownership_clause") // ม.572
  hasRepossessionClause Boolean @default(false) @map("has_repossession_clause")
  hasEarlyPayoffClause  Boolean @default(false) @map("has_early_payoff_clause")
  hasNoTransferClause   Boolean @default(false) @map("has_no_transfer_clause")
  hasAcknowledgement    Boolean @default(false) @map("has_acknowledgement") // ผู้ซื้อได้อ่านและเข้าใจ

  // Credit balance: เงินเกินที่ลูกค้าชำระเกินยอดค้าง (สำหรับ apply ในงวดถัดไป)
  creditBalance Decimal @default(0) @map("credit_balance") @db.Decimal(12, 2)

  // Dunning workflow: ระดับการติดตามหนี้
  dunningStage        DunningStage @default(NONE) @map("dunning_stage")
  dunningEscalatedAt  DateTime?    @map("dunning_escalated_at")
  dunningLastActionAt DateTime?    @map("dunning_last_action_at")

  // Retention policy
  retentionStatus DocumentRetentionStatus @default(ACTIVE) @map("retention_status")
  retentionExpiry DateTime?               @map("retention_expiry")
  legalHoldReason String?                 @map("legal_hold_reason")

  // Legacy migration tracking (จากโปรแกรมเขียว)
  legacyContractCode String? @unique @map("legacy_contract_code")

  payments                 Payment[]
  signatures               Signature[]
  eDocuments               EDocument[]
  callLogs                 CallLog[]
  repossession             Repossession?
  sale                     Sale?
  contractDocuments        ContractDocument[]
  creditCheck              CreditCheck?
  pdpaConsent              PDPAConsent?              @relation(fields: [pdpaConsentId], references: [id])
  receipts                 Receipt[]
  paymentLinks             PaymentLink[]
  paymentEvidences         PaymentEvidence[]
  kycVerifications         KycVerification[]
  loyaltyPoints            LoyaltyPoint[]
  interCompanyTransactions InterCompanyTransaction[]
  provisions               BadDebtProvision[]
  commissions              SalesCommission[]
  loyaltyRedemptions       LoyaltyRedemption[]
  assignedToId             String?                   @map("assigned_to_id") // collections agent assignment
  assignedTo               User?                     @relation("ContractAssignedTo", fields: [assignedToId], references: [id])

  // Collections tracking fields (Phase 5)
  collectionNotes  String?   @map("collection_notes") // internal notes from collector
  lastContactDate  DateTime? @map("last_contact_date") // last time customer was contacted

  // MDM (Mobile Device Management) lock tracking
  mdmLockedAt      DateTime? @map("mdm_locked_at")

  // Ads + CRM
  adsAttributions AdsAttribution[]
  crmLeads        CrmLead[]        @relation("CrmLeadContract")

  dunningActions   DunningAction[]

  // Shop warranty tracking
  shopWarrantyStartDate DateTime? @map("shop_warranty_start_date")
  shopWarrantyEndDate   DateTime? @map("shop_warranty_end_date")

  // วันที่ลูกค้ารับเครื่องจริง (ใช้เป็น baseline นับ 7-day defect exchange window)
  // Defaults to activatedAt/createdAt if not set
  deviceReceivedAt DateTime? @map("device_received_at")

  @@index([customerId])
  @@index([branchId])
  @@index([assignedToId])
  @@index([status])
  @@index([salespersonId])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([status, deletedAt, branchId])
  @@index([workflowStatus])
  @@index([parentContractId])
  @@index([retentionStatus])
  @@map("contracts")
}

model Payment {
  id              String         @id @default(uuid())
  contractId      String         @map("contract_id")
  installmentNo   Int            @map("installment_no")
  dueDate         DateTime       @map("due_date")
  amountDue       Decimal        @map("amount_due") @db.Decimal(12, 2)
  amountPaid      Decimal        @default(0) @map("amount_paid") @db.Decimal(12, 2)
  paidDate        DateTime?      @map("paid_date")
  paymentMethod   PaymentMethod? @map("payment_method")
  lateFee         Decimal        @default(0) @map("late_fee") @db.Decimal(12, 2)
  lateFeeWaived   Boolean        @default(false) @map("late_fee_waived")
  evidenceUrl     String?        @map("evidence_url")
  notes           String?
  status          PaymentStatus  @default(PENDING)
  recordedById    String?        @map("recorded_by_id")
  gatewayRef      String?        @map("gateway_ref")
  gatewayStatus   String?        @map("gateway_status")
  gatewayResponse Json?          @map("gateway_response")
  paidAt          DateTime?      @map("paid_at")

  // Payment breakdown (เงินต้น + ค่าคอม + ดอกเบี้ย + VAT = amountDue)
  monthlyPrincipal  Decimal? @map("monthly_principal") @db.Decimal(12, 2)
  monthlyInterest   Decimal? @map("monthly_interest") @db.Decimal(12, 2)
  monthlyCommission Decimal? @map("monthly_commission") @db.Decimal(12, 2)
  vatAmount         Decimal? @map("vat_amount") @db.Decimal(12, 2)

  // Legacy migration tracking (จากโปรแกรมเขียว)
  legacyInstallmentCode String? @unique @map("legacy_installment_code")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // onDelete: Restrict — payments are financial records. Refuse to delete
  // a contract while it still has payments. Use soft-delete on the contract
  // instead. Cascade was the original default but it would erase audit
  // trail in one accidental hard-delete (see ultraplan v3 audit).
  contract         Contract          @relation(fields: [contractId], references: [id], onDelete: Restrict)
  recordedBy       User?             @relation("RecordedBy", fields: [recordedById], references: [id])
  paymentLinks     PaymentLink[]
  paymentEvidences PaymentEvidence[]
  loyaltyPoint     LoyaltyPoint?
  dunningActions   DunningAction[]

  @@unique([contractId, installmentNo])
  @@index([contractId])
  @@index([dueDate])
  @@index([status])
  @@index([paidDate])
  @@index([status, dueDate])
  @@index([recordedById])
  @@map("payments")
}

// ============================================================
// INVENTORY & SUPPLIER
// ============================================================

model Supplier {
  id             String       @id @default(uuid())
  /// Entity type: JURISTIC = บริษัท/นิติบุคคล, INDIVIDUAL = บุคคลธรรมดา
  type           SupplierType @default(JURISTIC)
  name           String
  contactName    String?      @map("contact_name")
  contactPhone   String?      @map("contact_phone")
  contactPosition String?     @map("contact_position")
  nickname       String?
  /// Salutation for INDIVIDUAL type (นาย/นาง/นางสาว/คุณ)
  titleName      String?      @map("title_name")
  /// 5-digit branch code for JURISTIC type. "00000" = สำนักงานใหญ่. Required on tax invoices for VAT registrants.
  branchCode     String?      @map("branch_code")
  phone          String
  phoneSecondary String?      @map("phone_secondary")
  lineId         String?      @map("line_id")
  address        String?
  taxId          String?      @map("tax_id")
  hasVat         Boolean      @default(false) @map("has_vat")
  notes          String?
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  products       Product[]
  purchaseOrders PurchaseOrder[]
  paymentMethods SupplierPaymentMethod[]

  @@index([deletedAt])
  @@map("suppliers")
}

model SupplierPaymentMethod {
  id                String    @id @default(uuid())
  supplierId        String    @map("supplier_id")
  paymentMethod     String    @map("payment_method") // CASH, BANK_TRANSFER, CHECK, CREDIT
  bankName          String?   @map("bank_name")
  bankAccountName   String?   @map("bank_account_name")
  bankAccountNumber String?   @map("bank_account_number")
  creditTermDays    Int?      @map("credit_term_days")
  isDefault         Boolean   @default(false) @map("is_default")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
  @@map("supplier_payment_methods")
}

model PurchaseOrder {
  id            String          @id @default(uuid())
  poNumber      String          @unique @map("po_number")
  supplierId    String          @map("supplier_id")
  orderDate     DateTime        @map("order_date")
  expectedDate  DateTime?       @map("expected_date")
  dueDate       DateTime?       @map("due_date")
  status        POStatus        @default(DRAFT)
  totalAmount      Decimal         @map("total_amount") @db.Decimal(12, 2)
  discount         Decimal         @default(0) @db.Decimal(12, 2) // ส่วนลดก่อน VAT
  discountAfterVat Decimal         @default(0) @map("discount_after_vat") @db.Decimal(12, 2)
  vatAmount        Decimal         @default(0) @map("vat_amount") @db.Decimal(12, 2)
  netAmount        Decimal         @default(0) @map("net_amount") @db.Decimal(12, 2)
  paymentStatus POPaymentStatus @default(UNPAID) @map("payment_status")
  paymentMethod String?         @map("payment_method")
  paidAmount    Decimal         @default(0) @map("paid_amount") @db.Decimal(12, 2)
  paymentNotes  String?         @map("payment_notes")
  attachments   String[]        @default([])
  notes         String?
  stockCheckRef String?         @map("stock_check_ref") // Reference to stock alert that triggered this PO
  rejectReason  String?         @map("reject_reason") // Reason for rejection by Owner
  createdById   String          @map("created_by_id")
  approvedById  String?         @map("approved_by_id")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  deletedAt     DateTime?       @map("deleted_at")

  supplier   Supplier @relation(fields: [supplierId], references: [id])
  createdBy  User     @relation("POCreatedBy", fields: [createdById], references: [id])
  approvedBy User?    @relation("POApprovedBy", fields: [approvedById], references: [id])

  items           POItem[]
  products        Product[]
  goodsReceivings GoodsReceiving[]
  stockAlerts     StockAlert[]

  @@index([supplierId])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("purchase_orders")
}

model POItem {
  id             String   @id @default(uuid())
  poId           String   @map("po_id")
  brand          String?
  model          String?
  color          String?
  storage        String?
  category       String?
  accessoryType  String?  @map("accessory_type")
  accessoryBrand String?  @map("accessory_brand")
  quantity       Int
  unitPrice      Decimal  @map("unit_price") @db.Decimal(12, 2)
  receivedQty    Int       @default(0) @map("received_qty")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  purchaseOrder  PurchaseOrder        @relation(fields: [poId], references: [id], onDelete: Cascade)
  receivingItems GoodsReceivingItem[]

  @@index([poId])
  @@index([deletedAt])
  @@map("po_items")
}

model Product {
  id                 String          @id @default(uuid())
  name               String
  brand              String
  model              String
  color              String?
  storage            String?
  imeiSerial         String?         @unique @map("imei_serial")
  serialNumber       String?         @map("serial_number")
  category           ProductCategory
  costPrice          Decimal         @map("cost_price") @db.Decimal(12, 2)
  supplierId         String?         @map("supplier_id")
  poId               String?         @map("po_id")
  branchId           String          @map("branch_id")
  // Ownership tracking: which legal entity owns this product right now.
  // Default = branch's company (SHOP). When an installment contract becomes
  // ACTIVE, ownership transfers to FINANCE until payoff/repossession.
  ownedByCompanyId   String?         @map("owned_by_company_id")
  status             ProductStatus   @default(IN_STOCK)
  batteryHealth      Int?            @map("battery_health")
  shopWarrantyDays   Int?            @map("shop_warranty_days")
  warrantyExpired    Boolean?        @map("warranty_expired")
  warrantyExpireDate DateTime?       @map("warranty_expire_date")
  hasBox             Boolean?        @map("has_box")
  checklistResults   Json?           @map("checklist_results")
  accessoryType      String?         @map("accessory_type")
  accessoryBrand     String?         @map("accessory_brand")
  inspectionId       String?         @map("inspection_id")
  photos             String[]        @default([])
  stockInDate        DateTime?       @map("stock_in_date")

  // Legacy migration tracking (จากโปรแกรมเขียว)
  legacyProductCode String? @unique @map("legacy_product_code")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  supplier   Supplier?      @relation(fields: [supplierId], references: [id])
  po         PurchaseOrder? @relation(fields: [poId], references: [id])
  branch     Branch         @relation(fields: [branchId], references: [id])
  ownedBy    CompanyInfo?   @relation("ProductOwnership", fields: [ownedByCompanyId], references: [id])
  inspection Inspection?    @relation(fields: [inspectionId], references: [id])

  prices               ProductPrice[]
  contracts            Contract[]
  sales                Sale[]
  repossession         Repossession?
  receivingItem        GoodsReceivingItem?
  branchReceivingItems BranchReceivingItem[]
  stockTransfers       StockTransfer[]
  stockAdjustments     StockAdjustment[]
  stockCountItems      StockCountItem[]
  productPhotos        ProductPhoto?
  tradeIns             TradeIn[]

  @@index([branchId])
  @@index([status])
  @@index([category])
  @@index([brand, model])
  @@index([supplierId])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([branchId, status])
  @@index([ownedByCompanyId])
  @@map("products")
}

model ProductPhoto {
  id           String    @id @default(uuid())
  productId    String    @unique @map("product_id")
  front        String? // ด้านหน้า
  back         String? // ด้านหลัง
  left         String? // ข้างซ้าย
  right        String? // ข้างขวา
  top          String? // ด้านบน
  bottom       String? // ด้านล่าง
  isCompleted  Boolean   @default(false) @map("is_completed")
  uploadedById String?   @map("uploaded_by_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  uploadedBy User?   @relation("ProductPhotoUploadedBy", fields: [uploadedById], references: [id])

  @@map("product_photos")
}

model ProductPrice {
  id        String    @id @default(uuid())
  productId String    @map("product_id")
  label     String // e.g. "ราคาเงินสด", "ราคาผ่อน"
  amount    Decimal   @db.Decimal(12, 2)
  isDefault Boolean   @default(false) @map("is_default")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_prices")
}

model PricingTemplate {
  id                         String          @id @default(uuid())
  brand                      String
  model                      String
  storage                    String          @default("")
  category                   ProductCategory
  hasWarranty                Boolean         @default(false) @map("has_warranty") // false = ไม่เกี่ยว/ไม่มีประกัน, true = มีประกัน (มือ 2)
  cashPrice                  Decimal         @map("cash_price") @db.Decimal(12, 2)
  installmentBestchoicePrice Decimal         @map("installment_bestchoice_price") @db.Decimal(12, 2)
  installmentFinancePrice    Decimal         @map("installment_finance_price") @db.Decimal(12, 2)
  isActive                   Boolean         @default(true) @map("is_active")
  createdAt                  DateTime        @default(now()) @map("created_at")
  updatedAt                  DateTime        @updatedAt @map("updated_at")
  deletedAt                  DateTime?       @map("deleted_at")

  @@unique([brand, model, storage, category, hasWarranty])
  @@index([brand, model])
  @@index([category])
  @@map("pricing_templates")
}

model StockTransfer {
  id                   String         @id @default(uuid())
  batchNumber          String?        @map("batch_number") // เลขใบโอน เช่น TRF-2026-03-001
  productId            String         @map("product_id")
  fromBranchId         String         @map("from_branch_id")
  toBranchId           String         @map("to_branch_id")
  transferredBy        String         @map("transferred_by")
  notes                String?
  status               TransferStatus @default(PENDING)
  confirmedById        String?        @map("confirmed_by_id")
  confirmedAt          DateTime?      @map("confirmed_at")
  // IN_TRANSIT fields
  dispatchedById       String?        @map("dispatched_by_id")
  dispatchedAt         DateTime?      @map("dispatched_at")
  trackingNote         String?        @map("tracking_note")
  expectedDeliveryDate DateTime?      @map("expected_delivery_date")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")
  deletedAt            DateTime?      @map("deleted_at")

  product      Product @relation(fields: [productId], references: [id])
  fromBranch   Branch  @relation("TransferFrom", fields: [fromBranchId], references: [id])
  toBranch     Branch  @relation("TransferTo", fields: [toBranchId], references: [id])
  confirmedBy  User?   @relation("TransferConfirmedBy", fields: [confirmedById], references: [id])
  dispatchedBy User?   @relation("TransferDispatchedBy", fields: [dispatchedById], references: [id])

  branchReceiving BranchReceiving?

  @@index([productId])
  @@index([status])
  @@index([fromBranchId])
  @@index([toBranchId])
  @@index([batchNumber])
  @@index([createdAt])
  @@map("stock_transfers")
}

model GoodsReceiving {
  id           String    @id @default(uuid())
  poId         String    @map("po_id")
  receivedById String    @map("received_by_id")
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  po         PurchaseOrder        @relation(fields: [poId], references: [id], onDelete: Cascade)
  receivedBy User                 @relation("GoodsReceivedBy", fields: [receivedById], references: [id])
  items      GoodsReceivingItem[]

  @@index([poId])
  @@map("goods_receivings")
}

model GoodsReceivingItem {
  id                 String              @id @default(uuid())
  receivingId        String              @map("receiving_id")
  poItemId           String              @map("po_item_id")
  imeiSerial         String?             @map("imei_serial")
  serialNumber       String?             @map("serial_number")
  photos             String[]            @default([])
  status             ReceivingItemStatus
  rejectReason       String?             @map("reject_reason")
  batteryHealth      Int?                @map("battery_health")
  warrantyExpired    Boolean?            @map("warranty_expired")
  warrantyExpireDate DateTime?           @map("warranty_expire_date")
  hasBox             Boolean?            @map("has_box")
  checklistResults   Json?               @map("checklist_results")
  productId          String?             @unique @map("product_id")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  deletedAt          DateTime?           @map("deleted_at")

  receiving GoodsReceiving @relation(fields: [receivingId], references: [id], onDelete: Cascade)
  poItem    POItem         @relation(fields: [poItemId], references: [id])
  product   Product?       @relation(fields: [productId], references: [id])

  @@index([receivingId])
  @@index([poItemId])
  @@map("goods_receiving_items")
}

model StockAdjustment {
  id             String                @id @default(uuid())
  productId      String                @map("product_id")
  branchId       String                @map("branch_id")
  reason         StockAdjustmentReason
  previousStatus ProductStatus         @map("previous_status")
  notes          String?
  photos         String[]              @default([])
  adjustedById   String                @map("adjusted_by_id")
  // T5-C3 — every stock adjustment is 4-eyes: the adjuster records the
  // change, a different manager-tier user signs off as approver. These
  // fields are required in the service layer (DTO-validated). Existing
  // rows created before T5-C3 have NULL here — back-filled by migration
  // with adjustedById to preserve referential integrity.
  approvedById   String                @map("approved_by_id")
  approvedAt     DateTime              @default(now()) @map("approved_at")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")
  deletedAt      DateTime?             @map("deleted_at")

  product    Product @relation(fields: [productId], references: [id])
  branch     Branch  @relation(fields: [branchId], references: [id])
  adjustedBy User    @relation("StockAdjustedBy", fields: [adjustedById], references: [id])
  approvedBy User    @relation("StockAdjustmentApprovedBy", fields: [approvedById], references: [id])

  @@index([productId])
  @@index([branchId])
  @@index([reason])
  @@index([createdAt])
  @@map("stock_adjustments")
}

// ============================================================
// INSPECTION
// ============================================================

model InspectionTemplate {
  id         String    @id @default(uuid())
  name       String
  deviceType String    @map("device_type") // PHONE, TABLET
  isActive   Boolean   @default(true) @map("is_active")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  items       InspectionTemplateItem[]
  inspections Inspection[]

  @@map("inspection_templates")
}

model InspectionTemplateItem {
  id         String              @id @default(uuid())
  templateId String              @map("template_id")
  category   String
  itemName   String              @map("item_name")
  scoreType  InspectionScoreType @map("score_type")
  isRequired Boolean             @default(true) @map("is_required")
  weight     Decimal             @default(1) @db.Decimal(5, 2)
  sortOrder  Int                 @default(0) @map("sort_order")
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")
  deletedAt  DateTime?           @map("deleted_at")

  template InspectionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  results  InspectionResult[]

  @@index([templateId])
  @@map("inspection_template_items")
}

model Inspection {
  id             String          @id @default(uuid())
  productId      String          @map("product_id")
  templateId     String          @map("template_id")
  inspectorId    String          @map("inspector_id")
  inspectedAt    DateTime?       @map("inspected_at")
  overallGrade   ConditionGrade? @map("overall_grade")
  gradeOverride  ConditionGrade? @map("grade_override")
  overrideReason String?         @map("override_reason")
  photos         String[]        @default([])
  notes          String?
  isCompleted    Boolean         @default(false) @map("is_completed")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  deletedAt      DateTime?       @map("deleted_at")

  template  InspectionTemplate @relation(fields: [templateId], references: [id])
  inspector User               @relation(fields: [inspectorId], references: [id])
  products  Product[]

  results InspectionResult[]

  @@index([productId])
  @@index([templateId])
  @@index([inspectorId])
  @@map("inspections")
}

model InspectionResult {
  id             String          @id @default(uuid())
  inspectionId   String          @map("inspection_id")
  templateItemId String          @map("template_item_id")
  passFail       Boolean?        @map("pass_fail")
  grade          ConditionGrade?
  score          Decimal?        @db.Decimal(5, 2)
  numberValue    Decimal?        @map("number_value") @db.Decimal(10, 2)
  notes          String?
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  deletedAt      DateTime?       @map("deleted_at")

  inspection   Inspection             @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  templateItem InspectionTemplateItem @relation(fields: [templateItemId], references: [id])

  @@index([inspectionId])
  @@index([deletedAt])
  @@map("inspection_results")
}

// ============================================================
// DOCUMENTS & SIGNATURES
// ============================================================

model ContractTemplate {
  id           String    @id @default(uuid())
  name         String
  type         String // e.g. STORE_DIRECT, CREDIT_CARD, EXCHANGE
  contentHtml  String    @map("content_html")
  placeholders String[]  @default([])
  blocks       Json?     @default("[]") // Block-based editor content (JSON array)
  settings     Json? // Template settings (letterhead, margins, font sizes, etc.)
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  @@map("contract_templates")
}

model EDocument {
  id           String    @id @default(uuid())
  contractId   String    @map("contract_id")
  documentType String    @map("document_type") // CONTRACT, RECEIPT_DOWN, RECEIPT_INSTALLMENT, PAYOFF
  fileUrl      String    @map("file_url")
  fileHash     String    @map("file_hash") // SHA-256
  createdById  String    @map("created_by_id")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  // Restrict: legal/compliance documents (eIDAS proof). Cascade would
  // erase signed PDFs in one accidental hard-delete.
  contract Contract @relation(fields: [contractId], references: [id], onDelete: Restrict)

  @@index([contractId])
  @@index([createdById])
  @@map("e_documents")
}

model Signature {
  id             String     @id @default(uuid())
  contractId     String     @map("contract_id")
  signerType     SignerType @map("signer_type")
  signatureImage String     @map("signature_image") @db.Text // base64 PNG
  signatureSvg   String?    @map("signature_svg") @db.Text // SVG path data
  signerName     String?    @map("signer_name") // ชื่อผู้เซ็น
  ipAddress      String?    @map("ip_address")
  deviceInfo     String?    @map("device_info") // User-Agent
  screenSize     String?    @map("screen_size") // ขนาดหน้าจอ
  gpsLatitude    Float?     @map("gps_latitude")
  gpsLongitude   Float?     @map("gps_longitude")
  staffUserId    String?    @map("staff_user_id") // รหัสพนักงานที่ดำเนินการ
  contractHash   String?    @map("contract_hash") // SHA-256 hash ของสัญญา ณ เวลาเซ็น
  signedAt       DateTime   @default(now()) @map("signed_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")
  deletedAt      DateTime?  @map("deleted_at")

  // Restrict: e-signatures are eIDAS evidence and cannot be erased.
  contract Contract @relation(fields: [contractId], references: [id], onDelete: Restrict)

  @@index([contractId])
  @@map("signatures")
}

model StickerTemplate {
  id           String    @id @default(uuid())
  name         String
  sizeWidthMm  Int       @map("size_width_mm")
  sizeHeightMm Int       @map("size_height_mm")
  layoutConfig Json      @map("layout_config")
  placeholders String[]  @default([])
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  @@map("sticker_templates")
}

// ============================================================
// OPERATIONS
// ============================================================

model Repossession {
  id              String             @id @default(uuid())
  contractId      String             @unique @map("contract_id")
  productId       String             @unique @map("product_id")
  repossessedDate DateTime           @map("repossessed_date")
  conditionGrade  ConditionGrade     @map("condition_grade")
  appraisalPrice  Decimal            @map("appraisal_price") @db.Decimal(12, 2)
  appraisedById   String             @map("appraised_by_id")
  repairCost      Decimal            @default(0) @map("repair_cost") @db.Decimal(12, 2)
  resellPrice     Decimal?           @map("resell_price") @db.Decimal(12, 2)
  photos          String[]           @default([])
  status          RepossessionStatus @default(REPOSSESSED)
  soldContractId  String?            @map("sold_contract_id")
  notes           String?

  // ─── ราคากลาง + Profit/Loss calculation (FINANCE perspective, ex-VAT) ───
  marketValue           Decimal? @map("market_value") @db.Decimal(12, 2) // ราคากลาง (auto from trade-in pricing, editable)
  remainingMonths       Int?     @map("remaining_months") // จำนวนงวดคงค้าง
  financeCost           Decimal? @map("finance_cost") @db.Decimal(12, 2) // financedAmount + storeCommission (ต้นทุน FINANCE เต็ม)
  remainingCost         Decimal? @map("remaining_cost") @db.Decimal(12, 2) // (financeCost / totalMonths) × งวดคงค้าง
  discountPct           Decimal? @map("discount_pct") @db.Decimal(5, 2) // % ส่วนลดให้ลูกค้า (default 50)
  discountAmount        Decimal? @map("discount_amount") @db.Decimal(12, 2) // จำนวนส่วนลด
  closingAmount         Decimal? @map("closing_amount") @db.Decimal(12, 2) // ยอดปิดสัญญาที่ลูกค้าจ่าย
  customerRefundEnabled Boolean  @default(false) @map("customer_refund_enabled") // คืนเงินลูกค้าหรือไม่
  customerRefund        Decimal? @map("customer_refund") @db.Decimal(12, 2) // จำนวนเงินคืนลูกค้า
  profitLoss            Decimal? @map("profit_loss") @db.Decimal(12, 2) // กำไร/ขาดทุนสุทธิของบริษัท (+ = กำไร)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  contract    Contract @relation(fields: [contractId], references: [id])
  product     Product  @relation(fields: [productId], references: [id])
  appraisedBy User     @relation("AppraisedBy", fields: [appraisedById], references: [id])

  @@index([status])
  @@index([createdAt])
  @@map("repossessions")
}

// ============================================================
// COMMUNICATION & LOGGING
// ============================================================

model NotificationLog {
  id             String              @id @default(uuid())
  channel        NotificationChannel
  recipient      String // phone or LINE user ID
  subject        String?
  message        String
  status         String // SENT, FAILED, PENDING, RETRY_PENDING
  relatedId      String?             @map("related_id") // contract_id or payment_id
  errorMsg       String?             @map("error_msg")
  sentAt         DateTime?           @map("sent_at")
  retryCount     Int                 @default(0) @map("retry_count")
  nextRetryAt    DateTime?           @map("next_retry_at")
  externalId     String?             @map("external_id") // message_id from ThaiBulkSMS / LINE
  deliveryStatus String?             @map("delivery_status") // DELIVERED, UNDELIVERED, REJECTED, etc.
  deliveredAt    DateTime?           @map("delivered_at")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")
  deletedAt      DateTime?           @map("deleted_at")

  @@index([relatedId])
  @@index([channel])
  @@index([createdAt])
  @@index([status, channel])
  @@index([status, nextRetryAt])
  @@index([externalId])
  @@map("notification_logs")
}

model CallLog {
  id              String    @id @default(uuid())
  contractId      String    @map("contract_id")
  callerId        String    @map("caller_id")
  calledAt        DateTime  @map("called_at")
  result          String // e.g. ANSWERED, NO_ANSWER, PROMISED, REFUSED
  notes           String?
  settlementDate  DateTime? @map("settlement_date") // วันที่นัดชำระ (กรณี PROMISED)
  settlementNotes String?   @map("settlement_notes") // รายละเอียดการนัดชำระ
  /// Timestamp เมื่อ cron พบว่าลูกค้าผิดคำสัญญาชำระ (settlementDate ผ่านแล้วแต่ยังไม่ชำระ).
  /// ใช้ร่วมกับ result='PROMISED' เพื่อนับ broken-promise count → ป้อนเข้า dunning
  /// escalation และ credit-check ถัดไป
  brokenAt        DateTime? @map("broken_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  // Restrict: collections call history (promises, refusals) is the
  // primary evidence trail for the dunning workflow.
  contract Contract @relation(fields: [contractId], references: [id], onDelete: Restrict)
  caller   User     @relation(fields: [callerId], references: [id])

  @@index([contractId])
  @@index([callerId])
  @@index([result, settlementDate, brokenAt])
  @@map("call_logs")
}

model DunningRule {
  id                 String         @id @default(uuid())
  name               String
  triggerDay         Int            @map("trigger_day")
  channel            DunningChannel
  messageTemplate    String         @map("message_template")
  includePaymentLink Boolean        @default(false) @map("include_payment_link")
  autoExecute        Boolean        @default(true) @map("auto_execute")
  escalateTo         UserRole?      @map("escalate_to")
  isActive           Boolean        @default(true) @map("is_active")
  sortOrder          Int            @default(0) @map("sort_order")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")
  deletedAt          DateTime?      @map("deleted_at")

  actions            DunningAction[]

  @@index([triggerDay])
  @@index([isActive])
  @@map("dunning_rules")
}

model DunningAction {
  id               String              @id @default(uuid())
  dunningRuleId    String              @map("dunning_rule_id")
  dunningRule      DunningRule         @relation(fields: [dunningRuleId], references: [id], onDelete: Restrict)
  contractId       String              @map("contract_id")
  contract         Contract            @relation(fields: [contractId], references: [id], onDelete: Restrict)
  paymentId        String?             @map("payment_id")
  payment          Payment?            @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  channel          DunningChannel
  status           DunningActionStatus @default(PENDING)
  messageContent   String?             @map("message_content")
  result           String?
  paymentLinkUrl   String?             @map("payment_link_url")
  executedAt       DateTime?           @map("executed_at")
  executedById     String?             @map("executed_by_id")
  executedBy       User?               @relation("DunningActionExecutor", fields: [executedById], references: [id])
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")
  deletedAt        DateTime?           @map("deleted_at")

  @@unique([dunningRuleId, contractId, paymentId])
  @@index([contractId])
  @@index([status])
  @@index([createdAt])
  @@map("dunning_actions")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  action    String // CREATE, UPDATE, DELETE, EXCHANGE, REPOSSESSION, etc.
  entity    String // e.g. contract, payment, product
  entityId  String   @map("entity_id")
  oldValue  Json?    @map("old_value")
  newValue  Json?    @map("new_value")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  duration  Int? // request duration in ms
  createdAt DateTime @default(now()) @map("created_at")
  // T2-C4 — soft archive instead of hard delete so the row remains
  // queryable for forensics until the 7-year legal retention is actually
  // hit. A Postgres trigger (installed by migration 20260520300000)
  // rejects DELETE on this table regardless of path.
  archivedAt DateTime? @map("archived_at")

  user User @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@index([archivedAt])
  @@map("audit_logs")
}

model SystemConfig {
  id        String    @id @default(uuid())
  key       String    @unique
  value     String
  label     String? // Thai description
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@map("system_config")
}

// ============================================================
// POINT OF SALE
// ============================================================

model Sale {
  id                String         @id @default(uuid())
  saleNumber        String         @unique @map("sale_number")
  saleType          SaleType       @map("sale_type")
  customerId        String         @map("customer_id")
  productId         String         @map("product_id")
  branchId          String         @map("branch_id")
  salespersonId     String         @map("salesperson_id")
  sellingPrice      Decimal        @map("selling_price") @db.Decimal(12, 2)
  discount          Decimal        @default(0) @db.Decimal(12, 2)
  netAmount         Decimal        @map("net_amount") @db.Decimal(12, 2)
  paymentMethod     PaymentMethod? @map("payment_method")
  amountReceived    Decimal?       @map("amount_received") @db.Decimal(12, 2)
  contractId        String?        @unique @map("contract_id")
  financeCompany    String?        @map("finance_company")
  financeRefNumber  String?        @map("finance_ref_number")
  financeAmount     Decimal?       @map("finance_amount") @db.Decimal(12, 2)
  downPaymentAmount Decimal?       @map("down_payment_amount") @db.Decimal(12, 2)
  bundleProductIds  String[]       @default([]) @map("bundle_product_ids")
  notes             String?
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  deletedAt         DateTime?      @map("deleted_at")

  customer                 Customer                  @relation(fields: [customerId], references: [id])
  product                  Product                   @relation(fields: [productId], references: [id])
  branch                   Branch                    @relation(fields: [branchId], references: [id])
  salesperson              User                      @relation("SalesSalesperson", fields: [salespersonId], references: [id])
  contract                 Contract?                 @relation(fields: [contractId], references: [id])
  financeReceivable        FinanceReceivable?
  interCompanyTransactions InterCompanyTransaction[]
  commissions              SalesCommission[]
  promotionUsages          PromotionUsage[]

  @@index([saleType])
  @@index([branchId])
  @@index([createdAt])
  @@index([customerId])
  @@index([salespersonId])
  @@index([productId])
  @@index([deletedAt])
  @@map("sales")
}

// ============================================================
// INTEREST CONFIG & CONTRACT DOCUMENTS & CREDIT CHECK
// ============================================================

model InterestConfig {
  id                   String    @id @default(uuid())
  name                 String // เช่น "มือ 1", "มือ 2"
  productCategories    String[]  @default([]) @map("product_categories")
  interestRate         Decimal   @map("interest_rate") @db.Decimal(5, 4)
  minDownPaymentPct    Decimal   @map("min_down_payment_pct") @db.Decimal(5, 4)
  storeCommissionPct   Decimal   @default(0.10) @map("store_commission_pct") @db.Decimal(5, 4)
  vatPct               Decimal   @default(0.07) @map("vat_pct") @db.Decimal(5, 4)
  maxInstallmentMonths Int       @map("max_installment_months")
  minInstallmentMonths Int       @map("min_installment_months")
  isActive             Boolean   @default(true) @map("is_active")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  deletedAt            DateTime? @map("deleted_at")

  contracts Contract[]

  @@map("interest_configs")
}

model ContractDocument {
  id           String               @id @default(uuid())
  contractId   String               @map("contract_id")
  documentType ContractDocumentType @map("document_type")
  fileName     String               @map("file_name")
  originalName String?              @map("original_name") // ชื่อไฟล์เดิม
  fileUrl      String               @map("file_url")
  fileSize     Int?                 @map("file_size")
  mimeType     String?              @map("mime_type")
  fileHash     String?              @map("file_hash") // SHA-256
  version      Int                  @default(1) // version control
  isLatest     Boolean              @default(true) @map("is_latest")
  isImmutable  Boolean              @default(false) @map("is_immutable") // ห้ามลบ/แก้ไข
  notes        String?
  uploadedById String               @map("uploaded_by_id")
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")
  deletedAt    DateTime?            @map("deleted_at")

  // Restrict: contract documents (signed PDFs, KYC docs) are legal evidence.
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Restrict)
  uploadedBy User     @relation("DocumentUploadedBy", fields: [uploadedById], references: [id])

  @@index([contractId])
  @@index([documentType])
  @@index([contractId, documentType, isLatest])
  @@map("contract_documents")
}

model CreditCheck {
  id               String            @id @default(uuid())
  contractId       String?           @unique @map("contract_id")
  customerId       String            @map("customer_id")
  status           CreditCheckStatus @default(PENDING)
  bankName         String?           @map("bank_name")
  statementFiles   String[]          @default([]) @map("statement_files")
  statementMonths  Int               @default(3) @map("statement_months")
  aiAnalysis       Json?             @map("ai_analysis")
  aiScore          Int?              @map("ai_score")
  aiSummary        String?           @map("ai_summary")
  aiRecommendation String?           @map("ai_recommendation")

  // Salary slip analysis (AI)
  salaryVerified  Decimal? @map("salary_verified") @db.Decimal(12, 2)
  employerName    String?  @map("employer_name")
  salaryPayDay    Int?     @map("salary_pay_day") // วันที่เงินเดือนออก (1-31)
  salarySlipFiles String[] @default([]) @map("salary_slip_files")

  // Bank statement analysis (AI)
  statementBankName   String?  @map("statement_bank_name")
  statementAvgIncome  Decimal? @map("statement_avg_income") @db.Decimal(12, 2)
  statementAvgExpense Decimal? @map("statement_avg_expense") @db.Decimal(12, 2)
  statementAvgBalance Decimal? @map("statement_avg_balance") @db.Decimal(12, 2)

  // Risk assessment
  riskScore         String?  @map("risk_score") // LOW, MEDIUM, HIGH
  debtToIncomeRatio Decimal? @map("debt_to_income_ratio") @db.Decimal(5, 4)
  riskNote          String?  @map("risk_note")

  checkedById String?   @map("checked_by_id")
  checkedAt   DateTime? @map("checked_at")
  reviewNotes String?   @map("review_notes")

  // Override audit — เมื่อ manager เปลี่ยนผลจาก AI ต้องบันทึก original เพื่อ
  // ตรวจย้อนหลัง และบังคับให้ใส่ reason เพื่อสร้าง accountability
  originalStatus CreditCheckStatus? @map("original_status")
  originalScore  Int?               @map("original_score")
  overriddenAt   DateTime?          @map("overridden_at")
  overriddenById String?            @map("overridden_by_id")
  overrideReason String?            @map("override_reason")

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  contract     Contract? @relation(fields: [contractId], references: [id])
  customer     Customer  @relation(fields: [customerId], references: [id])
  checkedBy    User?     @relation("CreditCheckedBy", fields: [checkedById], references: [id])
  overriddenBy User?     @relation("CreditOverriddenBy", fields: [overriddenById], references: [id])

  @@index([contractId])
  @@index([customerId])
  @@index([status])
  @@index([overriddenById])
  @@map("credit_checks")
}

// ============================================================
// REORDER POINT & STOCK ALERTS
// ============================================================

model ReorderPoint {
  id              String          @id @default(uuid())
  brand           String
  model           String
  storage         String?
  category        ProductCategory
  branchId        String          @map("branch_id")
  minQuantity     Int             @map("min_quantity") // จำนวนขั้นต่ำก่อนแจ้งเตือน
  reorderQuantity Int             @map("reorder_quantity") // จำนวนที่แนะนำให้สั่ง
  isActive        Boolean         @default(true) @map("is_active")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  deletedAt       DateTime?       @map("deleted_at")

  branch      Branch       @relation(fields: [branchId], references: [id])
  stockAlerts StockAlert[]

  @@unique([brand, model, storage, category, branchId])
  @@index([branchId])
  @@index([isActive])
  @@map("reorder_points")
}

model StockAlert {
  id              String    @id @default(uuid())
  reorderPointId  String    @map("reorder_point_id")
  brand           String
  model           String
  storage         String?
  category        String
  branchId        String    @map("branch_id")
  currentStock    Int       @map("current_stock")
  minQuantity     Int       @map("min_quantity")
  reorderQuantity Int       @map("reorder_quantity")
  status          String    @default("ACTIVE") // ACTIVE, PO_CREATED, RESOLVED
  poId            String?   @map("po_id") // PO ที่สร้างจาก alert นี้
  resolvedAt      DateTime? @map("resolved_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  reorderPoint ReorderPoint   @relation(fields: [reorderPointId], references: [id])
  branch       Branch         @relation(fields: [branchId], references: [id])
  po           PurchaseOrder? @relation(fields: [poId], references: [id])

  @@index([status])
  @@index([branchId])
  @@index([reorderPointId])
  @@index([createdAt])
  @@map("stock_alerts")
}

// ============================================================
// STOCK COUNT (ตรวจนับสต๊อก)
// ============================================================

model StockCount {
  id          String    @id @default(uuid())
  countNumber String    @unique @map("count_number") // SC-YYYY-MM-NNN
  branchId    String    @map("branch_id")
  countedById String    @map("counted_by_id")
  status      String    @default("DRAFT") // DRAFT, IN_PROGRESS, COMPLETED, CANCELLED
  notes       String?
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  branch    Branch           @relation(fields: [branchId], references: [id])
  countedBy User             @relation("StockCountedBy", fields: [countedById], references: [id])
  items     StockCountItem[]

  @@index([branchId])
  @@index([status])
  @@index([createdAt])
  @@map("stock_counts")
}

model StockCountItem {
  id             String    @id @default(uuid())
  stockCountId   String    @map("stock_count_id")
  productId      String    @map("product_id")
  expectedStatus String    @map("expected_status") // status ในระบบ
  actualFound    Boolean   @default(false) @map("actual_found") // พบสินค้าจริง (default: ยังไม่ตรวจนับ)
  conditionNotes String?   @map("condition_notes")
  scannedImei    String?   @map("scanned_imei") // IMEI ที่สแกนยืนยัน
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  stockCount StockCount @relation(fields: [stockCountId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id])

  @@unique([stockCountId, productId])
  @@index([stockCountId])
  @@index([productId])
  @@map("stock_count_items")
}

// ============================================================
// BRANCH RECEIVING (สาขาเช็ครับสินค้า)
// ============================================================

model BranchReceiving {
  id           String    @id @default(uuid())
  transferId   String    @unique @map("transfer_id")
  receivedById String    @map("received_by_id")
  status       String    @default("PENDING") // PENDING, COMPLETED, PARTIAL_REJECT
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  transfer   StockTransfer         @relation(fields: [transferId], references: [id])
  receivedBy User                  @relation("BranchReceivedBy", fields: [receivedById], references: [id])
  items      BranchReceivingItem[]

  @@index([transferId])
  @@map("branch_receivings")
}

model BranchReceivingItem {
  id             String    @id @default(uuid())
  receivingId    String    @map("receiving_id")
  productId      String    @map("product_id")
  imeiSerial     String?   @map("imei_serial") // สแกนยืนยัน
  status         String    @default("PASS") // PASS, REJECT
  conditionNotes String?   @map("condition_notes")
  photos         String[]  @default([])
  rejectReason   String?   @map("reject_reason")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  receiving BranchReceiving @relation(fields: [receivingId], references: [id], onDelete: Cascade)
  product   Product         @relation(fields: [productId], references: [id])

  @@index([receivingId])
  @@index([productId])
  @@map("branch_receiving_items")
}

model RefreshToken {
  id        String    @id @default(uuid())
  token     String    @unique // stores SHA-256 hash of the actual token
  userId    String    @map("user_id")
  expiresAt DateTime  @map("expires_at")
  isRevoked Boolean   @default(false) @map("is_revoked")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String    @map("user_id")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model InviteToken {
  id        String    @id @default(uuid())
  token     String    @unique // SHA-256 hash of raw token
  email     String
  role      UserRole
  branchId  String?   @map("branch_id")
  invitedBy String    @map("invited_by")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  branch  Branch? @relation(fields: [branchId], references: [id])
  inviter User    @relation(fields: [invitedBy], references: [id])

  @@index([email])
  @@index([expiresAt])
  @@map("invite_tokens")
}

// ============================================================
// PDPA COMPLIANCE (คุ้มครองข้อมูลส่วนบุคคล)
// ============================================================

model PDPAConsent {
  id                String        @id @default(uuid())
  customerId        String        @map("customer_id")
  consentVersion    String        @map("consent_version") // version ของ Privacy Notice
  privacyNoticeText String        @map("privacy_notice_text") @db.Text // เนื้อหาที่ยินยอม
  purposes          String[]      @default([]) // วัตถุประสงค์ที่ยินยอม
  status            ConsentStatus @default(PENDING)
  grantedAt         DateTime?     @map("granted_at")
  revokedAt         DateTime?     @map("revoked_at")
  revokeReason      String?       @map("revoke_reason")
  ipAddress         String?       @map("ip_address")
  deviceInfo        String?       @map("device_info")
  signatureImage    String?       @map("signature_image") @db.Text // e-Sign ยินยอม
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @default(now()) @updatedAt @map("updated_at")
  deletedAt         DateTime?     @map("deleted_at")

  customer Customer  @relation(fields: [customerId], references: [id])
  contract Contract?

  @@index([customerId])
  @@index([status])
  @@map("pdpa_consents")
}

model DSARRequest {
  id            String          @id @default(uuid())
  requestNumber String          @unique @map("request_number") // DSAR-YYYY-NNN
  customerId    String          @map("customer_id")
  requestType   DSARRequestType @map("request_type")
  status        DSARStatus      @default(SUBMITTED)
  description   String          @db.Text
  responseNotes String?         @map("response_notes") @db.Text
  responseData  Json?           @map("response_data") // auto-generated data export for ACCESS requests
  processedById String?         @map("processed_by_id")
  submittedAt   DateTime        @default(now()) @map("submitted_at")
  processedAt   DateTime?       @map("processed_at")
  completedAt   DateTime?       @map("completed_at")
  dueDate       DateTime        @map("due_date") // ต้องดำเนินการภายใน 30 วัน
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  deletedAt     DateTime?       @map("deleted_at")

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@index([status])
  @@index([requestType])
  @@map("dsar_requests")
}

// ============================================================
// KYC VERIFICATION (Identity Verification before signing)
// ============================================================

model KycVerification {
  id         String @id @default(uuid())
  contractId String @map("contract_id")
  customerId String @map("customer_id")

  // OTP verification
  otpHash       String?   @map("otp_hash") // SHA-256 hash of OTP (never store plaintext)
  otpPhone      String    @map("otp_phone") // phone number OTP was sent to
  otpChannel    String    @map("otp_channel") // SMS | LINE
  otpAttempts   Int       @default(0) @map("otp_attempts") // failed attempts
  otpSentCount  Int       @default(0) @map("otp_sent_count") // times OTP was sent
  otpRefCode    String?   @map("otp_ref_code") // 4-char ref code shown to user
  otpVerifiedAt DateTime? @map("otp_verified_at")

  // ID Card photo verification
  idCardImageUrl String? @map("id_card_image_url") // S3 path
  idCardVerified Boolean @default(false) @map("id_card_verified")

  // Metadata
  ipAddress  String?   @map("ip_address")
  deviceInfo String?   @map("device_info") // User-Agent
  status     String    @default("PENDING") // PENDING, OTP_VERIFIED, VERIFIED, EXPIRED, FAILED
  expiresAt  DateTime  @map("expires_at") // OTP expiry (10 min)
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  contract Contract @relation(fields: [contractId], references: [id])
  customer Customer @relation(fields: [customerId], references: [id])

  @@index([contractId])
  @@index([customerId])
  @@index([status])
  @@map("kyc_verifications")
}

// ============================================================
// E-RECEIPT (ใบเสร็จรับเงินอิเล็กทรอนิกส์)
// ============================================================

model Receipt {
  id               String    @id @default(uuid())
  receiptNumber    String    @unique @map("receipt_number") // RC-YYYY-MM-NNNNN
  contractId       String    @map("contract_id")
  paymentId        String?   @map("payment_id")
  receiptType      String    @default("PAYMENT") // PAYMENT, DOWN_PAYMENT, EARLY_PAYOFF, CREDIT_NOTE
  payerName        String    @map("payer_name")
  payerAddress     String?   @map("payer_address")
  payerTaxId       String?   @map("payer_tax_id") // เลขประจำตัวผู้เสียภาษีผู้ซื้อ
  receiverName     String    @map("receiver_name")
  amount           Decimal   @db.Decimal(12, 2)
  amountBeforeVat  Decimal?  @map("amount_before_vat") @db.Decimal(12, 2) // ราคาก่อน VAT
  vatAmount        Decimal?  @map("vat_amount") @db.Decimal(12, 2) // จำนวน VAT
  installmentNo    Int?      @map("installment_no") // งวดที่
  remainingBalance Decimal?  @map("remaining_balance") @db.Decimal(12, 2)
  remainingMonths  Int?      @map("remaining_months")
  paymentMethod    String?   @map("payment_method")
  transactionRef   String?   @map("transaction_ref") // เลขอ้างอิงธุรกรรม
  itemDescription  String?   @map("item_description") // รายละเอียดสินค้า/บริการ
  paidDate         DateTime  @map("paid_date")
  fileUrl          String?   @map("file_url") // PDF URL
  fileHash         String?   @map("file_hash") // SHA-256
  isVoided         Boolean   @default(false) @map("is_voided")
  voidReason       String?   @map("void_reason")
  voidApprovedById String?   @map("void_approved_by_id") // ผู้อนุมัติการยกเลิก
  voidApprovedAt   DateTime? @map("void_approved_at")
  voidedReceiptId  String?   @map("voided_receipt_id") // อ้างอิงใบเสร็จที่ถูกยกเลิก
  issuedById       String    @map("issued_by_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  contract Contract @relation(fields: [contractId], references: [id])

  @@index([contractId])
  @@index([receiptNumber])
  @@index([paymentId])
  @@index([createdAt])
  @@map("receipts")
}

// ============================================================
// CUSTOMER DOCUMENT ACCESS (ลูกค้าเข้าถึงเอกสาร)
// ============================================================

model CustomerAccessToken {
  id          String    @id @default(uuid())
  token       String    @unique
  contractId  String    @map("contract_id")
  expiresAt   DateTime  @map("expires_at")
  accessedAt  DateTime? @map("accessed_at") // ครั้งแรกที่เข้าถึง
  accessCount Int       @default(0) @map("access_count")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([token])
  @@index([contractId])
  @@index([expiresAt])
  @@map("customer_access_tokens")
}

// ============================================================
// DOCUMENT AUDIT TRAIL (ประวัติการเข้าถึงเอกสาร)
// ============================================================

model DocumentAuditLog {
  id         String   @id @default(uuid())
  documentId String   @map("document_id") // ContractDocument ID
  contractId String   @map("contract_id")
  action     String // UPLOAD, VIEW, DOWNLOAD, PRINT, DELETE, HASH_MISMATCH
  userId     String?  @map("user_id")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  details    Json? // additional details
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([documentId])
  @@index([contractId])
  @@index([userId])
  @@index([createdAt])
  @@map("document_audit_logs")
}

// ============================================================
// COMPANY INFO (ข้อมูลบริษัท/ร้าน — สำหรับสัญญา)
// ============================================================

model CompanyInfo {
  id                 String  @id @default(uuid())
  nameTh             String  @map("name_th")
  nameEn             String? @map("name_en")
  taxId              String  @map("tax_id") // เลขทะเบียนนิติบุคคล/ผู้เสียภาษี
  companyCode        String? @unique @map("company_code") // "SHOP" / "FINANCE"
  address            String
  phone              String?
  directorName       String  @map("director_name") // ชื่อผู้มีอำนาจลงนาม
  directorPosition   String? @map("director_position") // ตำแหน่ง
  directorNationalId String? @map("director_national_id")
  directorAddress    String? @map("director_address")
  logoUrl            String? @map("logo_url")

  // VAT & Banking
  vatRegistered     Boolean  @default(false) @map("vat_registered")
  vatRate           Decimal? @map("vat_rate") @db.Decimal(5, 4) // e.g. 0.07 = 7%
  bankName          String?  @map("bank_name")
  bankAccountName   String?  @map("bank_account_name")
  bankAccountNumber String?  @map("bank_account_number")
  lineOaId          String?  @map("line_oa_id")

  isActive  Boolean   @default(true) @map("is_active")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  // Relations
  branches           Branch[]
  fromInterCompanyTx InterCompanyTransaction[] @relation("ICFromCompany")
  toInterCompanyTx   InterCompanyTransaction[] @relation("ICToCompany")
  journalEntries     JournalEntry[]
  taxReports         TaxReport[]
  ownedProducts      Product[]                 @relation("ProductOwnership")
  accountingPeriods  AccountingPeriod[]

  @@map("company_info")
}

// ============================================================
// TAX REPORTS (ภ.พ.30, ภ.ง.ด.3/53)
// ============================================================

model TaxReport {
  id          String        @id @default(uuid())
  companyId   String        @map("company_id")
  reportType  TaxReportType @map("report_type") // PP30, PND3, PND53
  reportYear  Int           @map("report_year")
  reportMonth Int           @map("report_month") // 1-12

  // PP30 fields (VAT)
  totalSales     Decimal? @map("total_sales") @db.Decimal(12, 2)
  totalVatOutput Decimal? @map("total_vat_output") @db.Decimal(12, 2)
  totalPurchases Decimal? @map("total_purchases") @db.Decimal(12, 2)
  totalVatInput  Decimal? @map("total_vat_input") @db.Decimal(12, 2)
  netVat         Decimal? @map("net_vat") @db.Decimal(12, 2) // output - input

  // PND fields (WHT)
  totalWht         Decimal? @map("total_wht") @db.Decimal(12, 2)
  transactionCount Int?     @map("transaction_count")

  // Common
  status        TaxReportStatus @default(DRAFT)
  generatedData Json?           @map("generated_data") // snapshot of line items
  notes         String?
  filedAt       DateTime?       @map("filed_at")
  filedById     String?         @map("filed_by_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  company CompanyInfo @relation(fields: [companyId], references: [id])
  filedBy User?       @relation("TaxReportFiledBy", fields: [filedById], references: [id])

  @@unique([companyId, reportType, reportYear, reportMonth])
  @@index([companyId])
  @@index([reportType])
  @@index([reportYear, reportMonth])
  @@index([status])
  @@map("tax_reports")
}

// ============================================================
// FIXED ASSET (สินทรัพย์ถาวร + ค่าเสื่อมราคา)
// ============================================================

enum AssetStatus {
  ACTIVE // ใช้งานอยู่
  FULLY_DEPRECIATED // หักค่าเสื่อมราคาครบแล้ว
  DISPOSED // จำหน่ายแล้ว
}

model FixedAsset {
  id               String      @id @default(uuid())
  assetCode        String      @unique @map("asset_code") // รหัสสินทรัพย์ e.g. "PA-20241200002"
  name             String // ชื่อสินทรัพย์
  description      String?
  category         String? // หมวดหมู่ (อุปกรณ์สำนักงาน, ส่วนปรับปรุงอาคาร, เครื่องตกแต่ง, ยานพาหนะ)
  branchId         String?     @map("branch_id")
  costValue        Decimal     @map("cost_value") @db.Decimal(12, 2) // ราคาทุนที่ซื้อมา
  salvageValue     Decimal     @default(0) @map("salvage_value") @db.Decimal(12, 2) // ราคาซาก (ปกติ 1 บาท หรือ 0)
  usefulLife       Int         @map("useful_life") // อายุการใช้งาน (จำนวนปี เช่น 5 ปี)
  purchaseDate     DateTime    @map("purchase_date") // วันที่ซื้อ/เริ่มใช้งาน
  accumulatedDepre Decimal     @default(0) @map("accumulated_depre") @db.Decimal(12, 2) // ค่าเสื่อมราคาสะสม
  status           AssetStatus @default(ACTIVE)
  disposedAt       DateTime?   @map("disposed_at")
  disposalNote     String?     @map("disposal_note")

  // Account codes for journal entries
  depreciationAccountCode String @default("53-1601") @map("depreciation_account_code") // Dr: ค่าเสื่อมราคา (Expense)
  accumulatedAccountCode  String @default("12-2102") @map("accumulated_account_code") // Cr: ค่าเสื่อมราคาสะสม (Contra Asset)

  createdById String?   @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  branch    Branch? @relation(fields: [branchId], references: [id])
  createdBy User?   @relation("AssetCreatedBy", fields: [createdById], references: [id])

  @@index([branchId])
  @@index([status])
  @@index([category])
  @@index([purchaseDate])
  @@map("fixed_assets")
}

// ============================================================
// LINE OA PAYMENT (ชำระเงินผ่าน LINE)
// ============================================================

enum PaymentLinkStatus {
  ACTIVE
  USED
  EXPIRED
}

enum EvidenceStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

model PaymentLink {
  id         String            @id @default(uuid())
  token      String            @unique
  contractId String            @map("contract_id")
  paymentId  String?           @map("payment_id")
  amount     Decimal           @db.Decimal(12, 2)
  status     PaymentLinkStatus @default(ACTIVE)
  expiresAt  DateTime          @map("expires_at")
  usedAt     DateTime?         @map("used_at")
  createdAt  DateTime          @default(now()) @map("created_at")
  deletedAt  DateTime?         @map("deleted_at")

  contract Contract @relation(fields: [contractId], references: [id])
  payment  Payment? @relation(fields: [paymentId], references: [id])

  @@index([token])
  @@index([contractId])
  @@index([status])
  @@index([deletedAt])
  @@map("payment_links")
}

model PaymentEvidence {
  id           String         @id @default(uuid())
  contractId   String         @map("contract_id")
  paymentId    String?        @map("payment_id")
  lineUserId   String?        @map("line_user_id")
  imageUrl     String         @map("image_url")
  amount       Decimal?       @db.Decimal(12, 2)
  status       EvidenceStatus @default(PENDING_REVIEW)
  reviewedById String?        @map("reviewed_by_id")
  reviewedAt   DateTime?      @map("reviewed_at")
  reviewNote   String?        @map("review_note")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @default(now()) @updatedAt @map("updated_at")
  deletedAt    DateTime?      @map("deleted_at")

  contract   Contract @relation(fields: [contractId], references: [id])
  payment    Payment? @relation(fields: [paymentId], references: [id])
  reviewedBy User?    @relation("EvidenceReviewedBy", fields: [reviewedById], references: [id])

  @@index([contractId])
  @@index([status])
  @@index([lineUserId])
  @@index([createdAt])
  @@map("payment_evidences")
}

// ============================================================
// FINANCE RECEIVABLE (เงินรับจากไฟแนนซ์)
// ============================================================

enum FinanceReceivableStatus {
  PENDING
  RECEIVED
  PARTIALLY_RECEIVED
  OVERDUE
  DISPUTED
}

model FinanceReceivable {
  id                String                  @id @default(uuid())
  saleId            String                  @unique @map("sale_id")
  branchId          String                  @map("branch_id")
  financeCompany    String                  @map("finance_company")
  financeRefNumber  String?                 @map("finance_ref_number")
  expectedAmount    Decimal                 @map("expected_amount") @db.Decimal(12, 2)
  commissionRate    Decimal?                @map("commission_rate") @db.Decimal(5, 4)
  commissionAmount  Decimal?                @map("commission_amount") @db.Decimal(12, 2)
  netExpectedAmount Decimal                 @map("net_expected_amount") @db.Decimal(12, 2)
  receivedAmount    Decimal?                @map("received_amount") @db.Decimal(12, 2)
  receivedDate      DateTime?               @map("received_date")
  bankRef           String?                 @map("bank_ref")
  expectedDate      DateTime                @map("expected_date")
  status            FinanceReceivableStatus @default(PENDING)
  note              String?
  recordedById      String?                 @map("recorded_by_id")
  createdAt         DateTime                @default(now()) @map("created_at")
  updatedAt         DateTime                @updatedAt @map("updated_at")
  deletedAt         DateTime?               @map("deleted_at")

  sale       Sale   @relation(fields: [saleId], references: [id])
  branch     Branch @relation(fields: [branchId], references: [id])
  recordedBy User?  @relation("FinanceRecordedBy", fields: [recordedById], references: [id])

  @@index([status])
  @@index([financeCompany])
  @@index([branchId])
  @@index([expectedDate])
  @@index([deletedAt])
  // Compound index for the dashboard's "outstanding by branch" query
  // (status + branchId is the most common WHERE combination — single
  // -column indexes can't be combined efficiently for high-cardinality
  // status filtering inside a branch).
  @@index([status, branchId])
  @@map("finance_receivables")
}

// ============================================================
// CHART OF ACCOUNTS (ผังบัญชี)
// ============================================================

enum AccountGroup {
  ASSET // 1xxx สินทรัพย์
  LIABILITY // 2xxx หนี้สิน
  EQUITY // 3xxx ส่วนของเจ้าของ
  REVENUE // 4xxx รายได้
  EXPENSE // 5xxx ค่าใช้จ่าย
}

model ChartOfAccount {
  id           String       @id @default(uuid())
  code         String       @unique // e.g. "1100", "4100"
  nameTh       String       @map("name_th") // ชื่อบัญชีภาษาไทย
  nameEn       String?      @map("name_en") // English name (optional)
  accountGroup AccountGroup @map("account_group")
  parentCode   String?      @map("parent_code") // parent account code for hierarchy
  level        Int          @default(1) // 1=group, 2=sub-group, 3=detail
  isActive     Boolean      @default(true) @map("is_active")

  // ── การใช้งานข้ามบริษัท (multi-entity) ──
  allowedCompanies String[] @default([]) @map("allowed_companies") // [] = ใช้ได้ทุกบริษัท, ["FINANCE"] = เฉพาะ FINANCE, ["SHOP"] = เฉพาะ SHOP

  // ── การ sync กับ PEAK (ระบบบัญชีภายนอก) ──
  peakAccountCode String? @map("peak_account_code") // รหัสบัญชีฝั่ง PEAK (สำหรับ export journal)
  peakAccountId   String? @map("peak_account_id")   // ID บัญชีบน PEAK API

  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  deletedAt    DateTime?    @map("deleted_at")

  @@index([accountGroup])
  @@index([code])
  @@map("chart_of_accounts")
}

// ============================================================
// JOURNAL ENTRY (บันทึกบัญชี — double-entry foundation)
// ============================================================

enum JournalEntryStatus {
  DRAFT
  POSTED
  VOIDED
}

model JournalEntry {
  id            String             @id @default(uuid())
  entryNumber   String             @unique @map("entry_number") // JE-YYYYMM-NNNN
  companyId     String             @map("company_id")
  entryDate     DateTime           @map("entry_date")
  description   String
  status        JournalEntryStatus @default(DRAFT)
  referenceType String?            @map("reference_type") // PAYMENT, EXPENSE, SALE, INTER_COMPANY, MANUAL
  referenceId   String?            @map("reference_id")
  postedAt      DateTime?          @map("posted_at")
  postedById    String?            @map("posted_by_id")
  createdById   String             @map("created_by_id")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  deletedAt     DateTime?          @map("deleted_at")
  peakSyncedAt  DateTime?          @map("peak_synced_at") // When synced to PEAK accounting

  company   CompanyInfo   @relation(fields: [companyId], references: [id])
  lines     JournalLine[]
  createdBy User          @relation("JournalCreatedBy", fields: [createdById], references: [id])
  postedBy  User?         @relation("JournalPostedBy", fields: [postedById], references: [id])

  @@index([companyId])
  @@index([entryDate])
  @@index([status])
  @@index([referenceType, referenceId])
  @@index([deletedAt])
  @@map("journal_entries")
  // Partial unique index enforced via migration (CREATE UNIQUE INDEX ... WHERE reference_type IS NOT NULL)
  // Prisma cannot express partial @@unique; see migration 20260428010000_journal_entries_ref_unique
}

model JournalLine {
  id             String    @id @default(uuid())
  journalEntryId String    @map("journal_entry_id")
  accountCode    String    @map("account_code") // maps to ChartOfAccount.code
  description    String?
  debit          Decimal   @default(0) @db.Decimal(12, 2)
  credit         Decimal   @default(0) @db.Decimal(12, 2)
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  journalEntry JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  @@index([journalEntryId])
  @@index([accountCode])
  @@map("journal_lines")
}

// ============================================================
// EXPENSE / บัญชีรายจ่าย (ผังบัญชีไทย หมวด 5)
// ============================================================

enum ExpenseAccountType {
  COST_OF_SALES
  SELLING_EXPENSE
  ADMINISTRATIVE_EXPENSE
  OTHER_EXPENSE
}

enum ExpenseCategory {
  // ── ต้นทุนขาย (5100) ──
  COGS_PRODUCT
  COGS_REPAIR_PARTS
  // ── ค่าใช้จ่ายในการขาย (5200) ──
  SELL_COMMISSION
  SELL_ADVERTISING
  SELL_TRANSPORT
  SELL_PACKAGING
  // ── ค่าใช้จ่ายในการบริหาร (5300) ──
  ADMIN_SALARY
  ADMIN_SOCIAL_SECURITY
  ADMIN_RENT
  ADMIN_UTILITIES
  ADMIN_OFFICE_SUPPLIES
  ADMIN_DEPRECIATION
  ADMIN_INSURANCE
  ADMIN_TAX_FEE
  ADMIN_MAINTENANCE
  ADMIN_TRAVEL
  ADMIN_TELEPHONE
  // ── ค่าใช้จ่ายอื่น (5900) ──
  OTHER_INTEREST
  OTHER_LOSS
  OTHER_FINE
  OTHER_MISC
}

enum ExpenseStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  PAID
  VOIDED
}

model Expense {
  id             String             @id @default(uuid())
  expenseNumber  String             @unique @map("expense_number")
  branchId       String             @map("branch_id")
  accountType    ExpenseAccountType @map("account_type")
  category       ExpenseCategory
  accountCode    String?            @map("account_code")
  description    String
  amount         Decimal            @db.Decimal(12, 2)
  vatAmount      Decimal            @default(0) @map("vat_amount") @db.Decimal(12, 2)
  totalAmount    Decimal            @map("total_amount") @db.Decimal(12, 2)
  withholdingTax Decimal            @default(0) @map("withholding_tax") @db.Decimal(12, 2)
  whtRate        Decimal?           @map("wht_rate") @db.Decimal(5, 4) // อัตราภาษีหัก ณ ที่จ่าย (0.01, 0.02, 0.03, 0.05)
  whtIncomeType  WhtIncomeType?     @map("wht_income_type") // ประเภทเงินได้ตาม ม.40
  netPayment     Decimal?           @map("net_payment") @db.Decimal(12, 2) // จำนวนจ่ายจริง = totalAmount - withholdingTax

  expenseDate   DateTime       @map("expense_date")
  paymentMethod PaymentMethod? @map("payment_method")
  paymentDate   DateTime?      @map("payment_date")
  reference     String?

  vendorName      String? @map("vendor_name")
  vendorTaxId     String? @map("vendor_tax_id")
  receiptImageUrl String? @map("receipt_image_url")
  taxInvoiceNo    String? @map("tax_invoice_no")

  status       ExpenseStatus @default(DRAFT)
  approvedById String?       @map("approved_by_id")
  approvedAt   DateTime?     @map("approved_at")
  rejectReason String?       @map("reject_reason")
  voidReason   String?       @map("void_reason")
  voidedById   String?       @map("voided_by_id")
  voidedAt     DateTime?     @map("voided_at")
  createdById  String        @map("created_by_id")

  isRecurring  Boolean @default(false) @map("is_recurring")
  recurringDay Int?    @map("recurring_day")

  note String?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  branch     Branch @relation(fields: [branchId], references: [id])
  createdBy  User   @relation("ExpenseCreatedBy", fields: [createdById], references: [id])
  approvedBy User?  @relation("ExpenseApprovedBy", fields: [approvedById], references: [id])
  voidedBy   User?  @relation("ExpenseVoidedBy", fields: [voidedById], references: [id])

  @@index([branchId])
  @@index([accountType])
  @@index([category])
  @@index([status])
  @@index([expenseDate])
  @@index([createdById])
  @@index([deletedAt])
  // Compound index for "expenses by branch in date range" — the most
  // common dashboard query. Single-column branchId + expenseDate scans
  // can't be combined as efficiently as a compound index.
  @@index([branchId, expenseDate])
  // Index for the approver dropdown filter on the expenses list
  @@index([approvedById])
  @@map("expenses")
}

// ============================================================
// LOYALTY PROGRAM (ระบบสะสมแต้มลูกค้า)
// ============================================================

model LoyaltyPoint {
  id         String    @id @default(uuid())
  customerId String    @map("customer_id")
  paymentId  String    @unique @map("payment_id") // idempotent: 1 payment = 1 point record
  contractId String    @map("contract_id")
  points     Int // 1 point per 100 baht, on-time only
  reason     String    @default("ON_TIME_PAYMENT")
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  deletedAt  DateTime? @map("deleted_at")

  customer Customer @relation(fields: [customerId], references: [id])
  payment  Payment  @relation(fields: [paymentId], references: [id])
  contract Contract @relation(fields: [contractId], references: [id])

  @@index([customerId])
  @@index([contractId])
  @@map("loyalty_points")
}

// ============================================================
// INTER-COMPANY TRANSACTIONS (BESTCHOICE SHOP ↔ BESTCHOICE FINANCE)
// ============================================================

model InterCompanyTransaction {
  id         String                        @id @default(uuid())
  saleId     String                        @map("sale_id")
  contractId String?                       @map("contract_id")
  branchId   String                        @map("branch_id")
  type       InterCompanyTransactionType
  status     InterCompanyTransactionStatus @default(PENDING)

  // Entity identification (legacy string fields — deprecated, use company FKs)
  fromEntity    String  @map("from_entity") // e.g. "BESTCHOICE FINANCE"
  toEntity      String  @map("to_entity") // e.g. "BESTCHOICE SHOP"
  fromCompanyId String? @map("from_company_id")
  toCompanyId   String? @map("to_company_id")

  // Financial fields
  principal     Decimal @db.Decimal(12, 2) // ยอดจัดไฟแนนซ์ (sellingPrice - downPayment)
  commission    Decimal @db.Decimal(12, 2) // Store commission (principal × commissionPct)
  commissionPct Decimal @map("commission_pct") @db.Decimal(5, 4) // e.g. 0.10
  vatAmount     Decimal @map("vat_amount") @db.Decimal(12, 2)
  vatPct        Decimal @map("vat_pct") @db.Decimal(5, 4) // e.g. 0.07
  totalAmount   Decimal @map("total_amount") @db.Decimal(12, 2) // principal + commission (Finance จ่ายให้ Shop)
  interestTotal Decimal @map("interest_total") @db.Decimal(12, 2)
  costPrice     Decimal @map("cost_price") @db.Decimal(12, 2)
  downPayment   Decimal @map("down_payment") @db.Decimal(12, 2)
  sellingPrice  Decimal @map("selling_price") @db.Decimal(12, 2)

  // Calculated profits (snapshot at creation time)
  shopProfit    Decimal @map("shop_profit") @db.Decimal(12, 2) // downPayment + principal + commission - costPrice
  financeProfit Decimal @map("finance_profit") @db.Decimal(12, 2) // interestTotal - commission (+ lateFees later)

  note         String?
  reconciledAt DateTime? @map("reconciled_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")

  sale        Sale         @relation(fields: [saleId], references: [id])
  contract    Contract?    @relation(fields: [contractId], references: [id])
  branch      Branch       @relation(fields: [branchId], references: [id])
  fromCompany CompanyInfo? @relation("ICFromCompany", fields: [fromCompanyId], references: [id])
  toCompany   CompanyInfo? @relation("ICToCompany", fields: [toCompanyId], references: [id])

  @@index([saleId])
  @@index([contractId])
  @@index([branchId])
  @@index([type])
  @@index([status])
  @@index([fromEntity])
  @@index([toEntity])
  @@index([fromCompanyId])
  @@index([toCompanyId])
  @@index([createdAt])
  @@index([deletedAt])
  @@map("inter_company_transactions")
}

// ============================================================
// SALES COMMISSION (ค่าคอมมิชชันพนักงานขาย)
// ============================================================

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  CLAWED_BACK
  PARTIALLY_CLAWED_BACK
}

enum CommissionRuleType {
  PERCENTAGE
  FIXED_AMOUNT
  TIERED
}

model CommissionRule {
  id            String             @id @default(uuid())
  name          String
  description   String?
  ruleType      CommissionRuleType @map("rule_type")
  rate          Decimal            @db.Decimal(5, 4) // e.g. 0.03 = 3%
  fixedAmount   Decimal?           @map("fixed_amount") @db.Decimal(12, 2)
  minSaleAmount Decimal?           @map("min_sale_amount") @db.Decimal(12, 2)
  maxSaleAmount Decimal?           @map("max_sale_amount") @db.Decimal(12, 2)
  isActive      Boolean            @default(true) @map("is_active")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  deletedAt     DateTime?          @map("deleted_at")

  commissions SalesCommission[]

  @@map("commission_rules")
}

model SalesCommission {
  id               String           @id @default(uuid())
  salespersonId    String           @map("salesperson_id")
  contractId       String?          @map("contract_id")
  saleId           String?          @map("sale_id")
  commissionRuleId String?          @map("commission_rule_id")
  period           String // "YYYY-MM" for monthly grouping
  saleAmount       Decimal          @map("sale_amount") @db.Decimal(12, 2)
  commissionRate   Decimal          @map("commission_rate") @db.Decimal(5, 4)
  commissionAmount Decimal          @map("commission_amount") @db.Decimal(12, 2)
  status           CommissionStatus @default(PENDING)
  approvedById     String?          @map("approved_by_id")
  approvedAt       DateTime?        @map("approved_at")
  paidAt           DateTime?        @map("paid_at")
  paidAmount       Decimal?         @map("paid_amount") @db.Decimal(12, 2)
  // Clawback on contract default. percent is 0-100 and amount = commission_amount × percent/100.
  // Set when the referenced contract enters DEFAULTED / WRITTEN_OFF / CLOSED_BAD_DEBT.
  clawbackAmount         Decimal?  @map("clawback_amount") @db.Decimal(12, 2)
  clawbackPercent        Int?      @map("clawback_percent")
  clawbackAt             DateTime? @map("clawback_at")
  clawbackReason         String?   @map("clawback_reason")
  monthsPaidBeforeDefault Int?     @map("months_paid_before_default")
  notes            String?
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  deletedAt        DateTime?        @map("deleted_at")

  salesperson    User            @relation("CommissionSalesperson", fields: [salespersonId], references: [id])
  contract       Contract?       @relation(fields: [contractId], references: [id])
  sale           Sale?           @relation(fields: [saleId], references: [id])
  commissionRule CommissionRule? @relation(fields: [commissionRuleId], references: [id])
  approvedBy     User?           @relation("CommissionApprovedBy", fields: [approvedById], references: [id])

  @@index([salespersonId])
  @@index([contractId])
  @@index([saleId])
  @@index([period])
  @@index([status])
  @@index([deletedAt])
  @@map("sales_commissions")
}

// ============================================================
// COMMISSION PAYOUT (ใบจ่ายคอมมิชชันรายเดือน — Phase 5)
// NOTE: Requires migration: prisma migrate dev --name add_commission_payout
// ============================================================

enum PayoutStatus {
  DRAFT     // สร้างแล้ว รอตรวจสอบ
  APPROVED  // อนุมัติแล้ว รอจ่าย
  PAID      // จ่ายแล้ว
  CANCELLED // ยกเลิก
}

model CommissionPayout {
  id             String       @id @default(uuid())
  salespersonId  String       @map("salesperson_id")
  period         String       // "YYYY-MM" เดือนที่จ่าย
  totalSales     Decimal      @map("total_sales") @db.Decimal(12, 2)
  totalCommission Decimal     @map("total_commission") @db.Decimal(12, 2)
  commissionCount Int         @default(0) @map("commission_count")
  status         PayoutStatus @default(DRAFT)
  notes          String?

  approvedById   String?   @map("approved_by_id")
  approvedAt     DateTime? @map("approved_at")
  paidById       String?   @map("paid_by_id")
  paidAt         DateTime? @map("paid_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  salesperson User  @relation("PayoutSalesperson", fields: [salespersonId], references: [id])
  approvedBy  User? @relation("PayoutApprovedBy", fields: [approvedById], references: [id])
  paidBy      User? @relation("PayoutPaidBy", fields: [paidById], references: [id])

  @@unique([salespersonId, period])
  @@index([salespersonId])
  @@index([period])
  @@index([status])
  @@index([deletedAt])
  @@map("commission_payouts")
}

// ============================================================
// LOYALTY REDEMPTION (แลกแต้ม)
// ============================================================

model LoyaltyRedemption {
  id             String    @id @default(uuid())
  customerId     String    @map("customer_id")
  points         Int // จำนวนแต้มที่ใช้ (ค่าบวก)
  reason         String // เหตุผลการแลก
  discountAmount Decimal   @map("discount_amount") @db.Decimal(12, 2)
  contractId     String?   @map("contract_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")

  customer Customer  @relation(fields: [customerId], references: [id])
  contract Contract? @relation(fields: [contractId], references: [id])

  @@index([customerId])
  @@map("loyalty_redemptions")
}

// ============================================================
// TRADE-IN VALUATION (รับซื้อเครื่องเก่า)
// ============================================================

enum TradeInStatus {
  PENDING_APPRAISAL
  APPRAISED
  ACCEPTED
  REJECTED
  COMPLETED
}

model TradeIn {
  id              String        @id @default(uuid())
  customerId      String?       @map("customer_id") // optional — walk-in seller may not be a customer
  productId       String?       @map("product_id") // new product being purchased (optional)
  branchId        String?       @map("branch_id") // สาขาที่รับซื้อ
  deviceBrand     String        @map("device_brand")
  deviceModel     String        @map("device_model")
  deviceStorage   String?       @map("device_storage")
  deviceColor     String?       @map("device_color")
  deviceCondition String?       @map("device_condition") // A/B/C/D
  imei            String?
  estimatedValue  Decimal?      @map("estimated_value") @db.Decimal(12, 2) // ราคาประเมินเบื้องต้น
  offeredPrice    Decimal?      @map("offered_price") @db.Decimal(12, 2) // ราคาที่เสนอ
  /// Snapshot ของ TradeInValuation.basePrice ตอน appraise — ใช้คำนวณ deviation
  /// ย้อนหลังและเป็น guardrail กันการเสนอราคาเกิน ±15% จากตารางกลาง
  basePriceAtAppraisal Decimal? @map("base_price_at_appraisal") @db.Decimal(12, 2)
  agreedPrice     Decimal?      @map("agreed_price") @db.Decimal(12, 2) // ราคาที่ตกลง
  status          TradeInStatus @default(PENDING_APPRAISAL)
  appraisedById   String?       @map("appraised_by_id")
  notes           String?

  // ─── ข้อมูลผู้ขาย (กรณี walk-in หรือ override จาก customer) ────────
  sellerName         String? @map("seller_name")
  sellerPhone        String? @map("seller_phone")
  sellerIdCardNumber String? @map("seller_id_card_number") // 13 หลัก, plaintext (consistent กับ Customer.nationalId — TODO encrypt ทั้งระบบทีหลัง)
  sellerAddress      String? @map("seller_address") // ที่อยู่ตามบัตร ปชช.

  // ─── หลักฐานบัตรประชาชน (anti-stolen-goods) ────────────────────────
  idCardPhotoUrl     String?   @map("id_card_photo_url") // S3 URL: รูปบัตร ปชช.
  idCardSource       String?   @map("id_card_source") // 'card_reader' | 'upload'
  idCardVerifiedAt   DateTime? @map("id_card_verified_at") // ผู้รับซื้อยืนยันตรวจบัตรแล้ว
  idCardVerifiedById String?   @map("id_card_verified_by_id")

  // ─── การยินยอม + ตรวจสอบของโจร ────────────────────────────────────
  sellerSignatureUrl       String?   @map("seller_signature_url") // ลายเซ็นผู้ขาย (S3 — legacy)
  sellerSignatureBase64    String?   @map("seller_signature_base64") @db.Text // ลายเซ็นผู้ขาย base64 (เก็บใน DB ตรง ๆ)
  voucherPrintedAt         DateTime? @map("voucher_printed_at") // ครั้งแรกที่พิมพ์ใบสำคัญ (ใช้ check "สำเนา")
  sellerConsentSigned      Boolean   @default(false) @map("seller_consent_signed")
  policeReportAcknowledged Boolean   @default(false) @map("police_report_acknowledged")
  imeiBlacklistCheckedAt   DateTime? @map("imei_blacklist_checked_at")
  imeiBlacklistResult      String?   @map("imei_blacklist_result") // 'clean' | 'duplicate' | 'flagged'

  // ─── วิธีชำระเงินให้ผู้ขาย ──────────────────────────────────────────
  paymentMethod         String? @map("payment_method") // 'CASH' | 'TRANSFER'
  transferBankName      String? @map("transfer_bank_name")
  transferAccountNumber String? @map("transfer_account_number")
  transferAccountName   String? @map("transfer_account_name")

  // ─── ใบสำคัญจ่ายเงิน ───────────────────────────────────────────────
  voucherNumber String?   @unique @map("voucher_number") // EXP-YYYYMMNNNNN
  voucherDate   DateTime? @map("voucher_date")
  voucherPdfUrl String?   @map("voucher_pdf_url")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  customer         Customer? @relation(fields: [customerId], references: [id])
  product          Product?  @relation(fields: [productId], references: [id])
  branch           Branch?   @relation(fields: [branchId], references: [id])
  appraisedBy      User?     @relation("TradeInAppraisedBy", fields: [appraisedById], references: [id])
  idCardVerifiedBy User?     @relation("TradeInIdCardVerifiedBy", fields: [idCardVerifiedById], references: [id])

  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@index([imei])
  @@index([branchId])
  // FK indexes for "appraisals by staff" and "id card verifications by staff" reports
  @@index([appraisedById])
  @@index([idCardVerifiedById])
  @@map("trade_ins")
}

// ============================================================
// TRADE-IN VALUATION TABLE (ตารางราคารับซื้อมาตรฐาน)
// ============================================================

model TradeInValuation {
  id        String   @id @default(uuid())
  brand     String   // ยี่ห้อ เช่น Apple, Samsung
  model     String   // รุ่น เช่น iPhone 15 Pro
  storage   String   // ความจุ เช่น 128GB, 256GB
  condition String   // A, B, C, D
  basePrice Decimal  @map("base_price") @db.Decimal(12, 2) // ราคารับซื้ออ้างอิง
  note      String?  // หมายเหตุพิเศษ

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([brand, model, storage, condition])
  @@index([brand])
  @@index([model])
  @@index([condition])
  @@index([deletedAt])
  @@map("trade_in_valuations")
}

// ============================================================
// PROMOTIONAL CAMPAIGNS (โปรโมชัน)
// ============================================================

enum PromotionType {
  PERCENTAGE_DISCOUNT // ลดราคา %
  FIXED_DISCOUNT // ลดราคาบาท
  FREE_ACCESSORY // แถมอุปกรณ์เสริม
  SPECIAL_RATE // อัตราดอกเบี้ยพิเศษ
}

model Promotion {
  id                  String        @id @default(uuid())
  name                String
  description         String?
  type                PromotionType
  discountValue       Decimal?      @map("discount_value") @db.Decimal(12, 2) // % or fixed amount
  specialInterestRate Decimal?      @map("special_interest_rate") @db.Decimal(5, 4)
  conditions          Json? // { minPurchase?, productIds?, categories? }
  startDate           DateTime      @map("start_date")
  endDate             DateTime      @map("end_date")
  maxUsageCount       Int?          @map("max_usage_count")
  currentUsageCount   Int           @default(0) @map("current_usage_count")
  isActive            Boolean       @default(true) @map("is_active")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")
  deletedAt           DateTime?     @map("deleted_at")

  usages PromotionUsage[]

  @@index([startDate, endDate])
  @@index([isActive])
  @@map("promotions")
}

model PromotionUsage {
  id              String    @id @default(uuid())
  promotionId     String    @map("promotion_id")
  saleId          String?   @map("sale_id")
  customerId      String    @map("customer_id")
  discountApplied Decimal   @map("discount_applied") @db.Decimal(12, 2)
  createdAt       DateTime  @default(now()) @map("created_at")
  deletedAt       DateTime? @map("deleted_at")

  promotion Promotion @relation(fields: [promotionId], references: [id])
  sale      Sale?     @relation(fields: [saleId], references: [id])
  customer  Customer  @relation(fields: [customerId], references: [id])

  @@index([promotionId])
  @@index([saleId])
  @@index([customerId])
  @@index([deletedAt])
  @@map("promotion_usages")
}

// ============================================================
// BAD DEBT PROVISIONING (ค่าเผื่อหนี้สงสัยจะสูญ)
// ============================================================

model BadDebtProvision {
  id                String    @id @default(uuid())
  contractId        String    @map("contract_id")
  provisionDate     DateTime  @map("provision_date")
  agingBucket       String    @map("aging_bucket") // "1-30", "31-60", "61-90", "91-180", "181-360", "360+"
  daysOverdue       Int       @map("days_overdue")
  outstandingAmount Decimal   @map("outstanding_amount") @db.Decimal(12, 2)
  provisionRate     Decimal   @map("provision_rate") @db.Decimal(5, 4) // e.g. 0.05 = 5%
  provisionAmount   Decimal   @map("provision_amount") @db.Decimal(12, 2)
  status            String    @default("ACTIVE") // ACTIVE, REVERSED, WRITTEN_OFF
  writtenOffAt      DateTime? @map("written_off_at")
  writtenOffById    String?   @map("written_off_by_id")
  approvedById      String?   @map("approved_by_id")
  approvedAt        DateTime? @map("approved_at")
  notes             String?
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")
  deletedAt         DateTime? @map("deleted_at")

  contract Contract @relation(fields: [contractId], references: [id])

  @@index([contractId])
  @@index([provisionDate])
  @@index([status])
  // FK indexes for the "writeoffs by approver" + "pending approvals" reports
  @@index([writtenOffById])
  @@index([approvedById])
  @@map("bad_debt_provisions")
}

// ============================================================
// TODO / TASK MANAGEMENT (\u0e07\u0e32\u0e19\u0e20\u0e32\u0e22\u0e43\u0e19\u0e17\u0e35\u0e21/\u0e2a\u0e32\u0e02\u0e32)
// ============================================================

model Todo {
  id          String       @id @default(uuid())
  title       String
  description String?      @db.Text
  status      TodoStatus   @default(TODO)
  priority    TodoPriority @default(MEDIUM)
  dueDate     DateTime?    @map("due_date")
  completedAt DateTime?    @map("completed_at")

  // Ownership / assignment
  createdById String  @map("created_by_id")
  assigneeId  String? @map("assignee_id")
  branchId    String? @map("branch_id") // optional scoping by branch

  // Tags as Postgres text[]
  tags String[] @default([])

  // JSON: [{ id, text, done }]
  checklist Json?

  // JSON: [{ url, name, size, mimeType, uploadedAt }]
  attachments Json?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  createdBy User  @relation("TodoCreatedBy", fields: [createdById], references: [id])
  assignee  User? @relation("TodoAssignedTo", fields: [assigneeId], references: [id])
  comments  TodoComment[]

  @@index([assigneeId])
  @@index([createdById])
  @@index([status])
  @@index([dueDate])
  @@index([branchId])
  @@map("todos")
}

model TodoComment {
  id      String @id @default(uuid())
  todoId  String @map("todo_id")
  todo    Todo   @relation(fields: [todoId], references: [id], onDelete: Cascade)
  userId  String @map("user_id")
  user    User   @relation("TodoCommentUser", fields: [userId], references: [id])
  content String @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  @@index([todoId, createdAt])
  @@map("todo_comments")
}

// ============================================================
// Chatbot (Finance Bot — น้องเบส)
// ============================================================

enum LineChannelType {
  SHOP
  FINANCE
  STAFF
}

enum ChatChannel {
  LINE_FINANCE
  LINE_SHOP
  FACEBOOK
  TIKTOK
  WEB
}

enum ChatRoomStatus {
  ACTIVE
  IDLE
}

enum ChatPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum MessageRole {
  CUSTOMER
  BOT
  STAFF
  AUTO_TRIGGER
  SYSTEM
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
  FILE
  STICKER
  LOCATION
  TEMPLATE
}

enum AutoTriggerType {
  REMINDER_T_MINUS_5
  REMINDER_T_MINUS_3
  REMINDER_T_MINUS_1
  REMINDER_T_DAY
  ESCALATION_T_PLUS_1
  ESCALATION_T_PLUS_3
  HOLIDAY_WARNING
  RECEIPT_DELIVERY
  CUSTOM_BROADCAST
}

enum TriggerStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

/// Multi-channel LINE binding (1 customer สามารถ link หลาย channel ได้)
/// linkedAt = createdAt (domain-meaningful alias). State transitions via unlinkedAt → deletedAt.
model CustomerLineLink {
  id         String          @id @default(uuid())
  customerId String          @map("customer_id")
  customer   Customer        @relation(fields: [customerId], references: [id])
  lineUserId String          @map("line_user_id")
  channel    LineChannelType
  linkedAt   DateTime        @default(now()) @map("linked_at")
  unlinkedAt DateTime?       @map("unlinked_at")
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")
  deletedAt  DateTime?       @map("deleted_at")

  @@unique([lineUserId, channel])
  @@unique([customerId, channel])
  @@index([customerId])
  @@index([lineUserId])
  @@index([deletedAt])
  @@map("customer_line_links")
}

/// Chat room — ลูกค้า 1 คน 1 room ต่อ channel
model ChatRoom {
  id             String    @id @default(uuid())
  lineUserId     String?   @map("line_user_id")
  externalUserId String?   @map("external_user_id") // FB PSID, TikTok user, web visitor ID
  customerId     String?   @map("customer_id")
  customer       Customer? @relation(fields: [customerId], references: [id])

  channel  ChatChannel   @default(LINE_FINANCE)
  status   ChatRoomStatus @default(ACTIVE)
  priority ChatPriority  @default(NORMAL)

  // Platform profile (fetched from LINE/FB on first contact — not always available for TikTok)
  displayName String? @map("display_name")
  pictureUrl  String? @map("picture_url")

  // Pin
  pinnedAt   DateTime? @map("pinned_at")
  pinnedById String?   @map("pinned_by_id")

  // Assignment
  assignedToId String? @map("assigned_to_id")
  assignedTo   User?   @relation("ChatAssignedStaff", fields: [assignedToId], references: [id])

  // Verification
  verifiedAt           DateTime? @map("verified_at")
  verificationAttempts Int       @default(0) @map("verification_attempts")

  // Handoff state
  handoffMode     Boolean   @default(false) @map("handoff_mode")
  handoffReason   String?   @map("handoff_reason")
  handoffTaggedAt DateTime? @map("handoff_tagged_at")
  handoffStaffId  String?   @map("handoff_staff_id")
  handoffStaff    User?     @relation("ChatHandoffStaff", fields: [handoffStaffId], references: [id])

  // Lead scoring & attribution
  leadScore         Int?              @map("lead_score")
  leadTemperature   String?           @map("lead_temperature")
  attributionId     String?           @map("attribution_id")
  attribution       AdsAttribution?   @relation(fields: [attributionId], references: [id])

  // SLA tracking
  firstResponseAt DateTime? @map("first_response_at")
  resolvedAt      DateTime? @map("resolved_at")

  // Stats
  unreadCount   Int      @default(0) @map("unread_count")
  totalMessages Int      @default(0) @map("total_messages")
  lastMessageAt DateTime @default(now()) @map("last_message_at")

  messages      ChatMessage[]
  feedbacks     ChatFeedback[]
  tags          ConversationTag[]
  notes         ChatNote[]
  snoozes       ChatSnooze[]
  sideMessages  ChatSideMessage[]
  trainingPairs AiTrainingPair[]
  autoReplyLogs AiAutoReplyLog[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([lineUserId, channel])
  @@index([customerId])
  @@index([assignedToId, status])
  @@index([status, priority])
  @@index([handoffMode, status])
  @@index([leadScore])
  @@map("chat_rooms")
}

/// Chat message — ทุกข้อความใน room
model ChatMessage {
  id                String   @id @default(uuid())
  externalMessageId String?  @unique @map("external_message_id") // LINE/FB/TikTok message ID
  roomId            String   @map("room_id")
  room              ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  role MessageRole
  type MessageType @default(TEXT)

  text      String? @db.Text
  mediaUrl  String? @map("media_url")
  mediaType String? @map("media_type")

  // Staff attribution
  staffId String? @map("staff_id")
  staff   User?   @relation("ChatMessageStaff", fields: [staffId], references: [id])

  // Delivery tracking
  deliveredAt DateTime? @map("delivered_at")
  readAt      DateTime? @map("read_at")

  // AI metadata
  intent       String?
  confidence   Float?
  toolsUsed    String[] @default([]) @map("tools_used")
  modelUsed    String?  @map("model_used")
  inputTokens  Int?     @map("input_tokens")
  outputTokens Int?     @map("output_tokens")
  costUsd      Decimal? @map("cost_usd") @db.Decimal(10, 6)

  // Vision metadata
  visionExtracted Json? @map("vision_extracted")

  // Linking
  paymentId String? @map("payment_id")
  receiptId String? @map("receipt_id")

  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([roomId, createdAt])
  @@index([intent])
  @@index([role])
  @@index([staffId])
  @@index([deletedAt])
  @@map("chat_messages")
}

/// Knowledge base entries (FAQ)
model ChatKnowledgeBase {
  id      String      @id @default(uuid())
  channel ChatChannel @default(LINE_FINANCE)

  category String
  intent   String

  triggerKeywords  String[] @default([]) @map("trigger_keywords")
  exampleQuestions String[] @default([]) @map("example_questions")

  responseTemplate String @map("response_template") @db.Text
  responseType     String @map("response_type") // "auto" | "handoff" | "info"

  requiresAuth  Boolean  @default(true) @map("requires_auth")
  requiresTools String[] @default([]) @map("requires_tools")

  active   Boolean @default(true)
  priority Int     @default(0)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([channel, intent])
  @@index([active, priority])
  @@map("chat_knowledge_base")
}

/// Auto-trigger schedule (reminders)
model ChatAutoTrigger {
  id         String   @id @default(uuid())
  customerId String   @map("customer_id")
  customer   Customer @relation(fields: [customerId], references: [id])

  triggerType  AutoTriggerType @map("trigger_type")
  scheduledFor DateTime        @map("scheduled_for")
  sentAt       DateTime?       @map("sent_at")
  status       TriggerStatus   @default(PENDING)

  /// Idempotency key (e.g. `${triggerType}:${paymentId}`).
  /// Combined with customerId enforces "1 trigger per (customer, target)"
  /// preventing duplicate sends from concurrent cron runs.
  referenceKey String @map("reference_key")

  payload Json

  messageId    String? @map("message_id")
  errorMessage String? @map("error_message")

  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([customerId, referenceKey])
  @@index([scheduledFor, status])
  @@index([customerId])
  @@index([deletedAt])
  @@map("chat_auto_triggers")
}

/// OTP request store — DB-backed for multi-instance scaling.
/// Replaces in-memory Map. Auto-cleaned by VerificationService.
model ChatbotOtpRequest {
  id            String   @id @default(uuid())
  lineUserId    String   @unique @map("line_user_id")
  customerId    String   @map("customer_id")
  phone         String
  hash          String
  expiresAt     DateTime @map("expires_at")
  attempts      Int      @default(0)
  lastRequestAt DateTime @map("last_request_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("chatbot_otp_requests")
}

/// Customer feedback on bot responses (👍/👎)
model ChatFeedback {
  id           String   @id @default(uuid())
  roomId       String   @map("room_id")
  room         ChatRoom @relation(fields: [roomId], references: [id])
  messageId    String?  @map("message_id")
  rating       Int      // 0=👎, 1=👍
  feedbackText String?  @map("feedback_text") @db.Text

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([roomId])
  @@index([rating])
  @@map("chat_feedbacks")
}

/// KB improvement suggestions from handoff/feedback/auto-analysis
model ChatKbSuggestion {
  id                String   @id @default(uuid())
  roomId            String   @map("room_id")
  customerQuestion  String   @map("customer_question") @db.Text
  staffAnswer       String?  @map("staff_answer") @db.Text
  suggestedIntent   String   @map("suggested_intent")
  suggestedKeywords String[] @default([]) @map("suggested_keywords")
  suggestedTemplate String?  @map("suggested_template") @db.Text
  source            String   // 'handoff' | 'low_rating' | 'auto_analysis'
  status            String   @default("PENDING") // PENDING | APPROVED | REJECTED
  reviewedById      String?  @map("reviewed_by_id")
  reviewedBy        User?    @relation("KbSuggestionReviewer", fields: [reviewedById], references: [id])
  reviewedAt        DateTime? @map("reviewed_at")
  kbEntryId         String?  @map("kb_entry_id")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([source])
  @@index([roomId])
  @@map("chat_kb_suggestions")
}

/// Outbound webhook subscriptions for external partners
model WebhookSubscription {
  id          String   @id @default(uuid())
  name        String
  url         String
  secret      String
  events      String[]
  isActive    Boolean  @default(true) @map("is_active")
  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  createdBy User @relation(fields: [createdById], references: [id])

  deliveries WebhookDelivery[]

  @@index([isActive, deletedAt])
  @@map("webhook_subscriptions")
}

/// Log of each webhook delivery attempt
model WebhookDelivery {
  id             String   @id @default(uuid())
  subscriptionId String   @map("subscription_id")
  eventType      String   @map("event_type")
  payload        Json
  statusCode     Int?     @map("status_code")
  success        Boolean  @default(false)
  errorMessage   String?  @map("error_message") @db.Text
  attemptCount   Int      @default(1) @map("attempt_count")
  deliveredAt    DateTime? @map("delivered_at")
  createdAt      DateTime @default(now()) @map("created_at")

  subscription WebhookSubscription @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId, createdAt])
  @@index([eventType])
  @@map("webhook_deliveries")
}

/// Idempotency table for LINE webhook dedup (replaces in-memory Map).
/// Prevents duplicate event processing across multi-instance Cloud Run.
model ProcessedWebhookEvent {
  id          String   @id @default(uuid())
  eventId     String   @unique @map("event_id")
  processedAt DateTime @default(now()) @map("processed_at")

  @@index([processedAt])
  @@map("processed_webhook_events")
}

// ============================================================
// UNIFIED CHAT ENGINE — Phase 1 foundation models
// ============================================================

/// Tags on chat rooms (e.g. "VIP", "refund", "complaint")
model ConversationTag {
  id        String   @id @default(uuid())
  roomId    String   @map("room_id")
  room      ChatRoom @relation(fields: [roomId], references: [id])
  tag       String   // free-form tag string
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([roomId, tag])
  @@index([tag])
  @@map("conversation_tags")
}

/// Pre-defined quick replies for staff ("/ขอบคุณ", "/ส่งสลิป" etc.)
model CannedResponse {
  id        String  @id @default(uuid())
  shortcut  String  @unique // "/thanks", "/slip" — searchable command
  title     String  // "ขอบคุณค่ะ" — display label
  content      String  @db.Text // full response text (may include placeholders)
  mediaUrl     String? @map("media_url") // optional image/file URL
  responseType String  @default("text") @map("response_type") // "text", "image", "flex"
  category     String? // "greeting", "payment", "general"
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([isActive, category])
  @@index([deletedAt])
  @@map("canned_responses")
}

/// Tracks staff online/offline + activity inside the chat system
model StaffChatActivity {
  id       String   @id @default(uuid())
  staffId  String   @map("staff_id")
  staff    User     @relation("StaffChatActivityUser", fields: [staffId], references: [id])
  action   String   // "online", "offline", "join_session", "leave_session", "reply"
  metadata Json?    // { sessionId, channel } etc.

  createdAt DateTime @default(now()) @map("created_at")

  @@index([staffId, createdAt])
  @@index([action])
  @@map("staff_chat_activities")
}

/// Internal staff notes on a chat room (not visible to customer)
model ChatNote {
  id      String   @id @default(uuid())
  roomId  String   @map("room_id")
  room    ChatRoom @relation(fields: [roomId], references: [id])
  staffId String   @map("staff_id")
  staff   User     @relation("ChatNoteStaff", fields: [staffId], references: [id])
  content String   @db.Text

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([roomId])
  @@index([staffId])
  @@index([deletedAt])
  @@map("chat_notes")
}

/// Snooze / follow-up reminder on a chat room
model ChatSnooze {
  id       String   @id @default(uuid())
  roomId   String   @map("room_id")
  room     ChatRoom @relation(fields: [roomId], references: [id])
  staffId  String   @map("staff_id")
  staff    User     @relation("ChatSnoozeStaff", fields: [staffId], references: [id])
  remindAt DateTime @map("remind_at")
  note     String?  @db.Text
  completed Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([remindAt, completed])
  @@index([staffId])
  @@map("chat_snoozes")
}

/// Internal staff-only side conversation on a chat room
model ChatSideMessage {
  id        String   @id @default(uuid())
  roomId    String   @map("room_id")
  room      ChatRoom @relation(fields: [roomId], references: [id])
  staffId   String   @map("staff_id")
  staff     User     @relation("ChatSideMessageStaff", fields: [staffId], references: [id])
  text      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([roomId])
  @@map("chat_side_messages")
}

// ============================================================
// ADS ATTRIBUTION — track campaign ROI
// ============================================================

enum AdsPlatform {
  LINE_ADS
  FACEBOOK_ADS
  TIKTOK_ADS
  GOOGLE_ADS
}

model AdsCampaign {
  id           String      @id @default(uuid())
  platform     AdsPlatform
  campaignId   String      @map("campaign_id")
  campaignName String      @map("campaign_name")
  adSetName    String?     @map("ad_set_name")
  adName       String?     @map("ad_name")
  budget       Decimal?    @db.Decimal(12, 2)
  startDate    DateTime?   @map("start_date")
  endDate      DateTime?   @map("end_date")
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  deletedAt    DateTime?   @map("deleted_at")

  attributions AdsAttribution[]

  @@unique([platform, campaignId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("ads_campaigns")
}

model AdsAttribution {
  id           String       @id @default(uuid())
  campaignId   String       @map("campaign_id")
  campaign     AdsCampaign  @relation(fields: [campaignId], references: [id])
  customerId   String?      @map("customer_id")
  customer     Customer?    @relation(fields: [customerId], references: [id])
  contractId   String?      @map("contract_id")
  contract     Contract?    @relation(fields: [contractId], references: [id])

  // Tracking data
  utmSource    String?      @map("utm_source")
  utmMedium    String?      @map("utm_medium")
  utmCampaign  String?      @map("utm_campaign")
  utmContent   String?      @map("utm_content")
  referrerUrl  String?      @map("referrer_url")

  // Attribution events
  firstTouch   DateTime     @map("first_touch")
  lastTouch    DateTime?    @map("last_touch")
  convertedAt  DateTime?    @map("converted_at")

  // Revenue (from contract)
  revenue      Decimal?     @db.Decimal(12, 2)
  createdAt    DateTime     @default(now()) @map("created_at")

  chatRooms  ChatRoom[]

  @@index([campaignId])
  @@index([customerId])
  @@index([utmSource, utmCampaign])
  @@map("ads_attributions")
}

// ============================================================
// CRM PIPELINE — lead tracking + customer scoring
// ============================================================

enum LeadStage {
  NEW_LEAD
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum LeadSource {
  CHAT
  WALK_IN
  REFERRAL
  ADS
  PHONE
}

enum CustomerTier {
  VIP
  STANDARD
  AT_RISK
  NEW
}

model CrmLead {
  id              String       @id @default(uuid())
  customerId      String?      @map("customer_id")
  customer        Customer?    @relation(fields: [customerId], references: [id])
  contractId      String?      @map("contract_id")
  contract        Contract?    @relation("CrmLeadContract", fields: [contractId], references: [id])

  stage           LeadStage    @default(NEW_LEAD)
  source          LeadSource
  channel         String?      // ChatChannel value if from chat

  // Assignment
  assignedToId    String?      @map("assigned_to_id")
  assignedTo      User?        @relation("CrmLeadAssignedTo", fields: [assignedToId], references: [id])
  branchId        String?      @map("branch_id")
  branch          Branch?      @relation(fields: [branchId], references: [id])

  // Product interest
  interestedProduct String?    @map("interested_product")
  estimatedValue    Decimal?   @db.Decimal(12, 2) @map("estimated_value")

  // Outcome
  lostReason   String?         @map("lost_reason")
  wonAt        DateTime?       @map("won_at")
  lostAt       DateTime?       @map("lost_at")

  // Follow-up
  nextFollowUp DateTime?       @map("next_follow_up")
  notes        CrmNote[]

  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  deletedAt    DateTime?        @map("deleted_at")

  @@index([stage, assignedToId])
  @@index([customerId])
  @@index([branchId, stage])
  @@index([deletedAt])
  @@map("crm_leads")
}

model CrmNote {
  id        String   @id @default(uuid())
  leadId    String   @map("lead_id")
  lead      CrmLead  @relation(fields: [leadId], references: [id])
  staffId   String   @map("staff_id")
  staff     User     @relation("CrmNoteStaff", fields: [staffId], references: [id])
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@index([leadId])
  @@map("crm_notes")
}

model CustomerScore {
  id              String       @id @default(uuid())
  customerId      String       @unique @map("customer_id")
  customer        Customer     @relation(fields: [customerId], references: [id])

  // Score components (0-100 each)
  paymentScore    Int          @default(50) @map("payment_score")
  engagementScore Int          @default(50) @map("engagement_score")
  valueScore      Int          @default(50) @map("value_score")
  riskScore       Int          @default(50) @map("risk_score")

  totalScore   Int             @default(50) @map("total_score")
  tier         CustomerTier    @default(STANDARD)

  lastCalculatedAt DateTime    @default(now()) @map("last_calculated_at")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  @@map("customer_scores")
}

// ============================================================
// DATA AUDIT — automated database health checks
// ============================================================

/// Stores results of each automated data audit check.
/// Groups checks by runId so a full audit run can be queried together.
model DataAuditLog {
  id         String   @id @default(uuid())
  runId      String   @map("run_id")
  checkName  String   @map("check_name")
  severity   String   // CRITICAL, HIGH, MEDIUM
  status     String   // PASS, FAIL, WARN
  count      Int      @default(0)
  details    Json?
  executedAt DateTime @default(now()) @map("executed_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([runId])
  @@index([checkName, executedAt])
  @@index([status])
  @@map("data_audit_logs")
}

// ============================================================
// ACCOUNTING PERIOD — monthly close lifecycle management
// ============================================================

/// Tracks the lifecycle of each accounting period (year+month) per company.
/// Status flows: OPEN → REVIEW → CLOSED → SYNCED
/// Once CLOSED, journals for that period are locked.
model AccountingPeriod {
  id        String  @id @default(uuid())
  companyId String  @map("company_id")
  company   CompanyInfo @relation(fields: [companyId], references: [id])
  year      Int
  month     Int
  status    AccountingPeriodStatus @default(OPEN)

  reviewStartedAt   DateTime? @map("review_started_at")
  reviewStartedById String?   @map("review_started_by_id")
  reviewStartedBy   User?     @relation("PeriodReviewStartedBy", fields: [reviewStartedById], references: [id])
  closedAt          DateTime? @map("closed_at")
  closedById        String?   @map("closed_by_id")
  closedBy          User?     @relation("PeriodClosedBy", fields: [closedById], references: [id])

  peakSyncedAt   DateTime? @map("peak_synced_at")
  peakSyncResult Json?     @map("peak_sync_result")
  reportSnapshot Json?     @map("report_snapshot")
  auditIssues    Json?     @map("audit_issues")
  notes          String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([companyId, year, month])
  @@index([status])
  @@map("accounting_periods")
}

// ============================================================
// AI TRAINING & AUTO-REPLY — chat AI improvement models
// ============================================================

/// Stores accepted/edited/rejected AI reply pairs for model fine-tuning
model AiTrainingPair {
  id              String    @id @default(uuid())
  type            String    // ACCEPT, EDIT, REJECT
  source          String    // SUGGEST_FEEDBACK, CHATCONE_IMPORT, SYSTEM_EXTRACT
  roomId          String?   @map("room_id")
  room            ChatRoom? @relation(fields: [roomId], references: [id])
  customerMessage String       @map("customer_message") @db.Text
  aiDraft         String?      @map("ai_draft") @db.Text
  humanEdit       String?      @map("human_edit") @db.Text
  intent          String?
  quality         Float?
  usedInPrompt    Boolean      @default(false) @map("used_in_prompt")
  createdAt       DateTime     @default(now()) @map("created_at")

  @@index([intent, quality])
  @@index([source])
  @@index([createdAt])
  @@map("ai_training_pairs")
}

/// Logs every AI auto-reply attempt for monitoring and confidence tracking
model AiAutoReplyLog {
  id              String   @id @default(uuid())
  roomId          String   @map("room_id")
  room            ChatRoom @relation(fields: [roomId], references: [id])
  customerMessage String   @map("customer_message") @db.Text
  aiReply         String   @map("ai_reply") @db.Text
  confidence      Float
  autoSent        Boolean  @map("auto_sent")
  handoffReason   String?  @map("handoff_reason")
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([roomId])
  @@index([autoSent, createdAt])
  @@map("ai_auto_reply_logs")
}

model BroadcastMessage {
  id            String    @id @default(uuid())
  messages      Json      // array: [{ type, content }] — supports up to 5 messages
  audience      String    // ALL, EXISTING, OVERDUE, NEW
  audienceCount Int       @map("audience_count")
  /// PENDING_APPROVAL (default — creator submits for review)
  /// APPROVED       (approver cleared; sent immediately or queued if scheduledAt in future)
  /// SCHEDULED      (approved + scheduledAt in future; cron picks up)
  /// SENT / FAILED / CANCELLED / REJECTED (terminal states)
  status        String    @default("PENDING_APPROVAL")
  scheduledAt   DateTime? @map("scheduled_at")
  sentAt        DateTime? @map("sent_at")
  errorMessage  String?   @map("error_message")
  createdById   String    @map("created_by_id")
  createdBy     User      @relation("BroadcastCreatedBy", fields: [createdById], references: [id])
  createdAt     DateTime  @default(now()) @map("created_at")

  /// SoD: approver ≠ creator. Enforced in service layer.
  approvedById   String?   @map("approved_by_id")
  approvedBy     User?     @relation("BroadcastApprovedBy", fields: [approvedById], references: [id])
  approvedAt     DateTime? @map("approved_at")
  rejectedById   String?   @map("rejected_by_id")
  rejectedBy     User?     @relation("BroadcastRejectedBy", fields: [rejectedById], references: [id])
  rejectedAt     DateTime? @map("rejected_at")
  rejectedReason String?   @map("rejected_reason")

  @@index([status, scheduledAt])
  @@index([createdAt])
  @@index([approvedById])
  @@index([rejectedById])
  @@map("broadcast_messages")
}
