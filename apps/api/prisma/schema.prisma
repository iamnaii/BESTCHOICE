model NotificationLog {
  id             String              @id @default(uuid())
  channel        NotificationChannel
  channelKey     String?             @map("channel_key") // 'line-shop' | 'line-finance' | 'line-staff' for LINE; null for SMS/IN_APP
  recipient      String // phone or LINE user ID
  subject        String?
  message        String
  status         String // SENT, FAILED, PENDING, RETRY_PENDING
  relatedId      String?             @map("related_id") // contract_id or payment_id
  errorMsg       String?             @map("error_msg")
  sentAt         DateTime?           @map("sent_at")
  retryCount     Int                 @default(0) @map("retry_count")
  nextRetryAt    DateTime?           @map("next_retry_at")
  externalId     String?             @map("external_id") // message_id from ThaiBulkSMS / LINE
  deliveryStatus String?             @map("delivery_status") // DELIVERED, UNDELIVERED, REJECTED, etc.
  deliveredAt    DateTime?           @map("delivered_at")
  customerId     String?             @map("customer_id")
  category       String?             @map("category") // DUNNING | REMINDER | TRANSACTIONAL | STAFF | MARKETING
  blockReason    String?             @map("block_reason") // OUTSIDE_HOURS | FREQUENCY_CAP | NO_CONSENT | HOLIDAY_BLOCK
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")
  deletedAt      DateTime?           @map("deleted_at")

