// ============================================================
// TODO / TASK MANAGEMENT (\u0e07\u0e32\u0e19\u0e20\u0e32\u0e22\u0e43\u0e19\u0e17\u0e35\u0e21/\u0e2a\u0e32\u0e02\u0e32)
// ============================================================

model Todo {
  id          String       @id @default(uuid())
  title       String
  description String?      @db.Text
  status      TodoStatus   @default(TODO)
  priority    TodoPriority @default(MEDIUM)
  dueDate     DateTime?    @map("due_date")
  completedAt DateTime?    @map("completed_at")

  // Ownership / assignment
  createdById String  @map("created_by_id")
  assigneeId  String? @map("assignee_id")
  branchId    String? @map("branch_id") // optional scoping by branch

  // Tags as Postgres text[]
  tags String[] @default([])

  // JSON: [{ id, text, done }]
  checklist Json?

  // JSON: [{ url, name, size, mimeType, uploadedAt }]
  attachments Json?

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  createdBy User          @relation("TodoCreatedBy", fields: [createdById], references: [id])
  assignee  User?         @relation("TodoAssignedTo", fields: [assigneeId], references: [id])
  comments  TodoComment[]

  @@index([assigneeId])
  @@index([createdById])
  @@index([status])
  @@index([dueDate])
  @@index([branchId])
  @@map("todos")
}

model TodoComment {
  id      String @id @default(uuid())
  todoId  String @map("todo_id")
  todo    Todo   @relation(fields: [todoId], references: [id], onDelete: Cascade)
  userId  String @map("user_id")
  user    User   @relation("TodoCommentUser", fields: [userId], references: [id])
  content String @db.Text

  createdAt DateTime @default(now()) @map("created_at")

  @@index([todoId, createdAt])
  @@map("todo_comments")
}

// ============================================================
// Chatbot (Finance Bot — น้องเบส)
// ============================================================

enum LineChannelType {
  SHOP
  FINANCE
  STAFF
}

enum ChatChannel {
  LINE_FINANCE
  LINE_SHOP
  FACEBOOK
  TIKTOK
  WEB
}

enum ChatRoomStatus {
  ACTIVE
  IDLE
}

enum ChatPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum MessageRole {
  CUSTOMER
  BOT
  STAFF
  AUTO_TRIGGER
  SYSTEM
}

enum MessageType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
  FILE
  STICKER
  LOCATION
  TEMPLATE
}

/// Z10: outbound LINE message delivery state, populated from
/// `events[].deliveryContext` on the LINE webhook + custom replies. Used by
/// queue.service `lineResponse` post-filter to surface RESPONDED/IGNORED/
/// BLOCKED contracts in the collections workflow.
enum ChatMessageDeliveryStatus {
  /// Message reached the user's device but no reply observed.
  DELIVERED
  /// User opened the chat (LINE read receipt).
  READ
  /// User responded — populated when an inbound message arrives shortly after
  /// our outbound send (within the response-window heuristic).
  RESPONDED
  /// Delivered but no engagement after the timeout window expired.
  IGNORED
  /// LINE rejected the send (e.g. user blocked the OA, or provider error).
  BLOCKED
}

enum AutoTriggerType {
  REMINDER_T_MINUS_5
  REMINDER_T_MINUS_3
  REMINDER_T_MINUS_1
  REMINDER_T_DAY
  ESCALATION_T_PLUS_1
  ESCALATION_T_PLUS_3
  HOLIDAY_WARNING
  RECEIPT_DELIVERY
  CUSTOM_BROADCAST
}

enum TriggerStatus {
  PENDING
  SENT
  FAILED
  CANCELLED
}

/// Multi-channel LINE binding (1 customer สามารถ link หลาย channel ได้)
/// linkedAt = createdAt (domain-meaningful alias). State transitions via unlinkedAt → deletedAt.
model CustomerLineLink {
  id         String          @id @default(uuid())
  customerId String          @map("customer_id")
  customer   Customer        @relation(fields: [customerId], references: [id])
  lineUserId String          @map("line_user_id")
  channel    LineChannelType
  linkedAt   DateTime        @default(now()) @map("linked_at")
  unlinkedAt DateTime?       @map("unlinked_at")
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")
  deletedAt  DateTime?       @map("deleted_at")

  @@unique([lineUserId, channel])
  @@unique([customerId, channel])
  @@index([customerId])
  @@index([lineUserId])
  @@index([deletedAt])
  @@map("customer_line_links")
}

/// Chat room — ลูกค้า 1 คน 1 room ต่อ channel
model ChatRoom {
  id             String    @id @default(uuid())
  lineUserId     String?   @map("line_user_id")
  externalUserId String?   @map("external_user_id") // FB PSID, TikTok user, web visitor ID
  customerId     String?   @map("customer_id")
  customer       Customer? @relation(fields: [customerId], references: [id])

  channel  ChatChannel    @default(LINE_FINANCE)
  status   ChatRoomStatus @default(ACTIVE)
  priority ChatPriority   @default(NORMAL)

  // Platform profile (fetched from LINE/FB on first contact — not always available for TikTok)
  displayName String? @map("display_name")
  pictureUrl  String? @map("picture_url")

  // Pin
  pinnedAt   DateTime? @map("pinned_at")
  pinnedById String?   @map("pinned_by_id")

  // Assignment
  assignedToId String? @map("assigned_to_id")
  assignedTo   User?   @relation("ChatAssignedStaff", fields: [assignedToId], references: [id])

  // Verification
  verifiedAt           DateTime? @map("verified_at")
  verificationAttempts Int       @default(0) @map("verification_attempts")

  // Handoff state
  handoffMode     Boolean   @default(false) @map("handoff_mode")
  handoffReason   String?   @map("handoff_reason")
  handoffTaggedAt DateTime? @map("handoff_tagged_at")
  handoffStaffId  String?   @map("handoff_staff_id")
  handoffStaff    User?     @relation("ChatHandoffStaff", fields: [handoffStaffId], references: [id])

  // Lead scoring & attribution
  leadScore       Int?            @map("lead_score")
  leadTemperature String?         @map("lead_temperature")
  attributionId   String?         @map("attribution_id")
  attribution     AdsAttribution? @relation(fields: [attributionId], references: [id])

  // SLA tracking
  firstResponseAt DateTime? @map("first_response_at")
  resolvedAt      DateTime? @map("resolved_at")

  // Stats
  unreadCount   Int      @default(0) @map("unread_count")
  totalMessages Int      @default(0) @map("total_messages")
  lastMessageAt DateTime @default(now()) @map("last_message_at")

  // AI pause state (Hybrid C take-over)
  aiPaused     Boolean   @default(false) @map("ai_paused")
  aiPausedAt   DateTime? @map("ai_paused_at")
  aiPausedById String?   @map("ai_paused_by_id")
  aiPausedBy   User?     @relation("ChatRoomAiPausedBy", fields: [aiPausedById], references: [id])

  messages      ChatMessage[]
  feedbacks     ChatFeedback[]
  tags          ConversationTag[]
  notes         ChatNote[]
  snoozes       ChatSnooze[]
  sideMessages  ChatSideMessage[]
  trainingPairs AiTrainingPair[]
  autoReplyLogs AiAutoReplyLog[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([lineUserId, channel])
  @@index([customerId])
  @@index([assignedToId, status])
  @@index([status, priority])
  @@index([handoffMode, status])
  @@index([leadScore])
  // Speeds up the */5min first-response SLA cron in chat-engine/chat-cron.service.ts
  @@index([status, firstResponseAt, createdAt])
  @@map("chat_rooms")
}

/// Chat message — ทุกข้อความใน room
model ChatMessage {
  id                String   @id @default(uuid())
  externalMessageId String?  @unique @map("external_message_id") // LINE/FB/TikTok message ID
  roomId            String   @map("room_id")
  room              ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)

  role MessageRole
  type MessageType @default(TEXT)

  text      String? @db.Text
  mediaUrl  String? @map("media_url")
  mediaType String? @map("media_type")

  /// LINE Flex Message JSON for type=TEMPLATE messages — staff inbox renders
  /// a preview that mirrors what customer received. NULL for non-Flex messages.
  flexJson Json? @map("flex_json")

  // Staff attribution
  staffId String? @map("staff_id")
  staff   User?   @relation("ChatMessageStaff", fields: [staffId], references: [id])

  // Delivery tracking
  deliveredAt    DateTime?                  @map("delivered_at")
  readAt         DateTime?                  @map("read_at")
  // Z10: outbound delivery state populated from LINE webhook
  // `events[].deliveryContext`. NULL for inbound (customer→us) messages and
  // for outbound messages we sent before this column existed.
  deliveryStatus ChatMessageDeliveryStatus? @map("delivery_status")

  // AI metadata
  intent       String?
  confidence   Float?
  toolsUsed    String[] @default([]) @map("tools_used")
  modelUsed    String?  @map("model_used")
  inputTokens  Int?     @map("input_tokens")
  outputTokens Int?     @map("output_tokens")
  costUsd      Decimal? @map("cost_usd") @db.Decimal(10, 6)

  // Vision metadata
  visionExtracted Json? @map("vision_extracted")

  // Linking
  paymentId String? @map("payment_id")
  receiptId String? @map("receipt_id")

  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([roomId, createdAt])
  @@index([intent])
  @@index([role])
  @@index([staffId])
  @@index([deletedAt])
  @@map("chat_messages")
}

/// Knowledge base entries (FAQ)
model ChatKnowledgeBase {
  id      String      @id @default(uuid())
  channel ChatChannel @default(LINE_FINANCE)

  category String
  intent   String

  triggerKeywords  String[] @default([]) @map("trigger_keywords")
  exampleQuestions String[] @default([]) @map("example_questions")

  responseTemplate String @map("response_template") @db.Text
  responseType     String @map("response_type") // "auto" | "handoff" | "info"

  requiresAuth  Boolean  @default(true) @map("requires_auth")
  requiresTools String[] @default([]) @map("requires_tools")

  active   Boolean @default(true)
  priority Int     @default(0)

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([channel, intent])
  @@index([active, priority])
  @@map("chat_knowledge_base")
}

/// Auto-trigger schedule (reminders)
model ChatAutoTrigger {
  id         String   @id @default(uuid())
  customerId String   @map("customer_id")
  customer   Customer @relation(fields: [customerId], references: [id])

  triggerType  AutoTriggerType @map("trigger_type")
  scheduledFor DateTime        @map("scheduled_for")
  sentAt       DateTime?       @map("sent_at")
  status       TriggerStatus   @default(PENDING)

  /// Idempotency key (e.g. `${triggerType}:${paymentId}`).
  /// Combined with customerId enforces "1 trigger per (customer, target)"
  /// preventing duplicate sends from concurrent cron runs.
  referenceKey String @map("reference_key")

  payload Json

  messageId    String? @map("message_id")
  errorMessage String? @map("error_message")

  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")

  @@unique([customerId, referenceKey])
  @@index([scheduledFor, status])
  @@index([customerId])
  @@index([deletedAt])
  @@map("chat_auto_triggers")
}

/// OTP request store — DB-backed for multi-instance scaling.
/// Replaces in-memory Map. Auto-cleaned by VerificationService.
model ChatbotOtpRequest {
  id            String   @id @default(uuid())
  lineUserId    String   @unique @map("line_user_id")
  customerId    String   @map("customer_id")
  phone         String
  hash          String
  expiresAt     DateTime @map("expires_at")
  attempts      Int      @default(0)
  lastRequestAt DateTime @map("last_request_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([expiresAt])
  @@map("chatbot_otp_requests")
}

/// Customer feedback on bot responses (👍/👎)
model ChatFeedback {
  id           String   @id @default(uuid())
  roomId       String   @map("room_id")
  room         ChatRoom @relation(fields: [roomId], references: [id])
  messageId    String?  @map("message_id")
  rating       Int // 0=👎, 1=👍
  feedbackText String?  @map("feedback_text") @db.Text

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([roomId])
  @@index([rating])
  @@map("chat_feedbacks")
}

/// KB improvement suggestions from handoff/feedback/auto-analysis
model ChatKbSuggestion {
  id                String    @id @default(uuid())
  roomId            String    @map("room_id")
  customerQuestion  String    @map("customer_question") @db.Text
  staffAnswer       String?   @map("staff_answer") @db.Text
  suggestedIntent   String    @map("suggested_intent")
  suggestedKeywords String[]  @default([]) @map("suggested_keywords")
  suggestedTemplate String?   @map("suggested_template") @db.Text
  source            String // 'handoff' | 'low_rating' | 'auto_analysis'
  status            String    @default("PENDING") // PENDING | APPROVED | REJECTED
  reviewedById      String?   @map("reviewed_by_id")
  reviewedBy        User?     @relation("KbSuggestionReviewer", fields: [reviewedById], references: [id])
  reviewedAt        DateTime? @map("reviewed_at")
  kbEntryId         String?   @map("kb_entry_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([source])
  @@index([roomId])
  @@map("chat_kb_suggestions")
}

/// Outbound webhook subscriptions for external partners
model WebhookSubscription {
  id          String    @id @default(uuid())
  name        String
  url         String
  secret      String
  events      String[]
  isActive    Boolean   @default(true) @map("is_active")
  createdById String    @map("created_by_id")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  createdBy User @relation(fields: [createdById], references: [id])

  deliveries WebhookDelivery[]

  @@index([isActive, deletedAt])
  @@map("webhook_subscriptions")
}

/// Log of each webhook delivery attempt
model WebhookDelivery {
  id             String    @id @default(uuid())
  subscriptionId String    @map("subscription_id")
  eventType      String    @map("event_type")
  payload        Json
  statusCode     Int?      @map("status_code")
  success        Boolean   @default(false)
  errorMessage   String?   @map("error_message") @db.Text
  attemptCount   Int       @default(1) @map("attempt_count")
  deliveredAt    DateTime? @map("delivered_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  subscription WebhookSubscription @relation(fields: [subscriptionId], references: [id])

  @@index([subscriptionId, createdAt])
  @@index([eventType])
  @@map("webhook_deliveries")
}

/// Idempotency table for LINE webhook dedup (replaces in-memory Map).
/// Prevents duplicate event processing across multi-instance Cloud Run.
model ProcessedWebhookEvent {
  id          String   @id @default(uuid())
  eventId     String   @unique @map("event_id")
  processedAt DateTime @default(now()) @map("processed_at")

  @@index([processedAt])
  @@map("processed_webhook_events")
}

