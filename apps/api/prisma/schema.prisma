generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  SALES
  BRANCH_MANAGER
  ACCOUNTANT
  OWNER
}

enum ContractStatus {
  DRAFT
  ACTIVE
  OVERDUE
  DEFAULT
  EARLY_PAYOFF
  COMPLETED
  EXCHANGED
  CLOSED_BAD_DEBT
}

enum PlanType {
  STORE_DIRECT
  CREDIT_CARD
  STORE_WITH_INTEREST
}

enum ProductStatus {
  PO_RECEIVED
  QC_PENDING // รอตรวจสอบคุณภาพ (ก่อนเข้าคลัง)
  PHOTO_PENDING // รอถ่ายรูปสินค้า 6 มุม (หลัง QC ผ่าน)
  INSPECTION
  IN_STOCK
  RESERVED
  SOLD_INSTALLMENT
  SOLD_CASH
  REPOSSESSED
  REFURBISHED
  SOLD_RESELL
  DAMAGED
  LOST
  WRITTEN_OFF
}

enum ProductCategory {
  PHONE_NEW
  PHONE_USED
  TABLET
  ACCESSORY
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  QR_EWALLET
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIALLY_PAID
  OVERDUE
}

enum POStatus {
  DRAFT
  APPROVED
  PENDING
  PARTIALLY_RECEIVED
  FULLY_RECEIVED
  CANCELLED
}

enum POPaymentStatus {
  UNPAID
  DEPOSIT_PAID
  PARTIALLY_PAID
  FULLY_PAID
}

enum ReceivingItemStatus {
  PASS
  REJECT
}

enum TransferStatus {
  PENDING
  IN_TRANSIT // กำลังจัดส่ง
  CONFIRMED
  REJECTED
}

enum InspectionScoreType {
  PASS_FAIL
  GRADE
  SCORE_1_5
  NUMBER
}

enum ConditionGrade {
  A
  B
  C
  D
}

enum SignerType {
  CUSTOMER
  STAFF
}

enum NotificationChannel {
  LINE
  SMS
  IN_APP
}

enum RepossessionStatus {
  REPOSSESSED
  UNDER_REPAIR
  READY_FOR_SALE
  SOLD
}

enum StockAdjustmentReason {
  DAMAGED
  LOST
  FOUND
  CORRECTION
  WRITE_OFF
  OTHER
}

enum SaleType {
  CASH
  INSTALLMENT
  EXTERNAL_FINANCE
}

enum ContractWorkflowStatus {
  CREATING // กำลังสร้าง
  PENDING_REVIEW // รอตรวจสอบ
  APPROVED // อนุมัติแล้ว
  REJECTED // ปฏิเสธ (ส่งกลับแก้ไข)
}

enum CreditCheckStatus {
  PENDING
  APPROVED
  REJECTED
  MANUAL_REVIEW
}

enum ContractDocumentType {
  SIGNED_CONTRACT
  ID_CARD_COPY
  KYC
  FACEBOOK_PROFILE
  FACEBOOK_POST
  LINE_PROFILE
  DEVICE_RECEIPT_PHOTO
  BANK_STATEMENT
  OTHER
}

// ============================================================
// CORE ENTITIES
// ============================================================

model Branch {
  id        String   @id @default(uuid())
  name      String
  location  String?
  phone     String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  isMainWarehouse Boolean @default(false) @map("is_main_warehouse")

  users            User[]
  products         Product[]
  contracts        Contract[]
  sales            Sale[]
  stockFroms       StockTransfer[]   @relation("TransferFrom")
  stockTos         StockTransfer[]   @relation("TransferTo")
  stockAdjustments StockAdjustment[]
  reorderPoints    ReorderPoint[]
  stockAlerts      StockAlert[]
  stockCounts      StockCount[]

  @@map("branches")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole @default(SALES)
  branchId  String?  @map("branch_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  branch Branch? @relation(fields: [branchId], references: [id])

  contractsAsSalesperson Contract[]         @relation("Salesperson")
  contractsReviewed      Contract[]         @relation("ContractReviewer")
  salesAsSalesperson     Sale[]             @relation("SalesSalesperson")
  paymentsRecorded       Payment[]          @relation("RecordedBy")
  inspections            Inspection[]
  callLogs               CallLog[]
  auditLogs              AuditLog[]
  purchaseOrdersCreated  PurchaseOrder[]    @relation("POCreatedBy")
  purchaseOrdersApproved PurchaseOrder[]    @relation("POApprovedBy")
  repossessionsAppraised Repossession[]     @relation("AppraisedBy")
  goodsReceivings        GoodsReceiving[]   @relation("GoodsReceivedBy")
  transfersConfirmed     StockTransfer[]    @relation("TransferConfirmedBy")
  transfersDispatched    StockTransfer[]    @relation("TransferDispatchedBy")
  stockAdjustments       StockAdjustment[]  @relation("StockAdjustedBy")
  documentsUploaded      ContractDocument[] @relation("DocumentUploadedBy")
  creditChecks           CreditCheck[]      @relation("CreditCheckedBy")
  branchReceivings       BranchReceiving[]  @relation("BranchReceivedBy")
  stockCounts            StockCount[]       @relation("StockCountedBy")
  productPhotosUploaded  ProductPhoto[]     @relation("ProductPhotoUploadedBy")

  @@index([branchId])
  @@map("users")
}

model Customer {
  id               String    @id @default(uuid())
  nationalId       String    @unique @map("national_id") // encrypted AES-256
  prefix           String? // คำนำหน้า (นาย, นาง, นางสาว)
  name             String
  nickname         String? // ชื่อเล่น
  isForeigner      Boolean   @default(false) @map("is_foreigner") // ต่างด้าว
  birthDate        DateTime? @map("birth_date") // วันเกิด
  phone            String
  phoneSecondary   String?   @map("phone_secondary")
  email            String? // อีเมล
  lineId           String?   @map("line_id")
  facebookLink     String?   @map("facebook_link") // ลิงก์ Facebook
  facebookName     String?   @map("facebook_name") // ชื่อ Facebook
  facebookFriends  String?   @map("facebook_friends") // จำนวนเพื่อน Facebook
  googleMapLink    String?   @map("google_map_link") // Link Google Map
  addressIdCard    String?   @map("address_id_card")
  addressCurrent   String?   @map("address_current")
  occupation       String?
  occupationDetail String?   @map("occupation_detail") // รายละเอียดอาชีพ
  salary           Decimal?  @db.Decimal(12, 2) // เงินเดือน
  workplace        String?
  addressWork      String?   @map("address_work") // ที่อยู่ที่ทำงาน
  references       Json? // บุคคลอ้างอิง [{prefix, firstName, lastName, phone, relationship}]
  documents        String[]  @default([]) // array of file URLs
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  contracts    Contract[]
  sales        Sale[]
  creditChecks CreditCheck[]

  @@index([phone])
  @@index([name])
  @@map("customers")
}

model Contract {
  id               String         @id @default(uuid())
  contractNumber   String         @unique @map("contract_number")
  customerId       String         @map("customer_id")
  productId        String         @map("product_id")
  branchId         String         @map("branch_id")
  salespersonId    String         @map("salesperson_id")
  planType         PlanType       @map("plan_type")
  sellingPrice     Decimal        @map("selling_price") @db.Decimal(12, 2)
  downPayment      Decimal        @map("down_payment") @db.Decimal(12, 2)
  interestRate     Decimal        @map("interest_rate") @db.Decimal(5, 4) // e.g. 0.0800
  totalMonths      Int            @map("total_months")
  interestTotal    Decimal        @map("interest_total") @db.Decimal(12, 2)
  financedAmount   Decimal        @map("financed_amount") @db.Decimal(12, 2)
  monthlyPayment   Decimal        @map("monthly_payment") @db.Decimal(12, 2)
  status           ContractStatus @default(DRAFT)
  parentContractId String?        @map("parent_contract_id")
  notes            String?
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  deletedAt        DateTime?      @map("deleted_at")

  // Workflow: สองฝ่าย (ทำสัญญา vs ตรวจสอบ)
  workflowStatus ContractWorkflowStatus @default(CREATING) @map("workflow_status")
  reviewedById   String?                @map("reviewed_by_id")
  reviewedAt     DateTime?              @map("reviewed_at")
  reviewNotes    String?                @map("review_notes")

  // วันที่ครบกำหนดชำระ ตามวันเงินเดือนออก (1-28)
  paymentDueDay Int? @map("payment_due_day")

  // ที่มาดอกเบี้ย
  interestConfigId String? @map("interest_config_id")

  customer       Customer        @relation(fields: [customerId], references: [id])
  product        Product         @relation(fields: [productId], references: [id])
  branch         Branch          @relation(fields: [branchId], references: [id])
  salesperson    User            @relation("Salesperson", fields: [salespersonId], references: [id])
  parentContract Contract?       @relation("ContractExchange", fields: [parentContractId], references: [id])
  childContracts Contract[]      @relation("ContractExchange")
  reviewedBy     User?           @relation("ContractReviewer", fields: [reviewedById], references: [id])
  interestConfig InterestConfig? @relation(fields: [interestConfigId], references: [id])

  payments          Payment[]
  signatures        Signature[]
  eDocuments        EDocument[]
  callLogs          CallLog[]
  repossession      Repossession?
  sale              Sale?
  contractDocuments ContractDocument[]
  creditCheck       CreditCheck?

  @@index([customerId])
  @@index([branchId])
  @@index([status])
  @@index([salespersonId])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([status, deletedAt, branchId])
  @@index([workflowStatus])
  @@index([parentContractId])
  @@map("contracts")
}

model Payment {
  id            String         @id @default(uuid())
  contractId    String         @map("contract_id")
  installmentNo Int            @map("installment_no")
  dueDate       DateTime       @map("due_date")
  amountDue     Decimal        @map("amount_due") @db.Decimal(12, 2)
  amountPaid    Decimal        @default(0) @map("amount_paid") @db.Decimal(12, 2)
  paidDate      DateTime?      @map("paid_date")
  paymentMethod PaymentMethod? @map("payment_method")
  lateFee       Decimal        @default(0) @map("late_fee") @db.Decimal(12, 2)
  lateFeeWaived Boolean        @default(false) @map("late_fee_waived")
  evidenceUrl   String?        @map("evidence_url")
  notes         String?
  status        PaymentStatus  @default(PENDING)
  recordedById  String?        @map("recorded_by_id")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  recordedBy User?    @relation("RecordedBy", fields: [recordedById], references: [id])

  @@unique([contractId, installmentNo])
  @@index([contractId])
  @@index([dueDate])
  @@index([status])
  @@index([paidDate])
  @@index([status, dueDate])
  @@index([recordedById])
  @@map("payments")
}

// ============================================================
// INVENTORY & SUPPLIER
// ============================================================

model Supplier {
  id             String   @id @default(uuid())
  name           String
  contactName    String   @map("contact_name")
  nickname       String?
  phone          String
  phoneSecondary String?  @map("phone_secondary")
  lineId         String?  @map("line_id")
  address        String?
  taxId          String?  @map("tax_id")
  hasVat         Boolean  @default(false) @map("has_vat")
  notes          String?
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  products       Product[]
  purchaseOrders PurchaseOrder[]
  paymentMethods SupplierPaymentMethod[]

  @@map("suppliers")
}

model SupplierPaymentMethod {
  id                String   @id @default(uuid())
  supplierId        String   @map("supplier_id")
  paymentMethod     String   @map("payment_method") // CASH, BANK_TRANSFER, CHECK, CREDIT
  bankName          String?  @map("bank_name")
  bankAccountName   String?  @map("bank_account_name")
  bankAccountNumber String?  @map("bank_account_number")
  creditTermDays    Int?     @map("credit_term_days")
  isDefault         Boolean  @default(false) @map("is_default")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@index([supplierId])
  @@map("supplier_payment_methods")
}

model PurchaseOrder {
  id            String          @id @default(uuid())
  poNumber      String          @unique @map("po_number")
  supplierId    String          @map("supplier_id")
  orderDate     DateTime        @map("order_date")
  expectedDate  DateTime?       @map("expected_date")
  dueDate       DateTime?       @map("due_date")
  status        POStatus        @default(DRAFT)
  totalAmount   Decimal         @map("total_amount") @db.Decimal(12, 2)
  discount      Decimal         @default(0) @db.Decimal(12, 2)
  vatAmount     Decimal         @default(0) @map("vat_amount") @db.Decimal(12, 2)
  netAmount     Decimal         @default(0) @map("net_amount") @db.Decimal(12, 2)
  paymentStatus POPaymentStatus @default(UNPAID) @map("payment_status")
  paymentMethod String?         @map("payment_method")
  paidAmount    Decimal         @default(0) @map("paid_amount") @db.Decimal(12, 2)
  paymentNotes  String?         @map("payment_notes")
  attachments   String[]        @default([])
  notes         String?
  stockCheckRef String?         @map("stock_check_ref") // Reference to stock alert that triggered this PO
  rejectReason  String?         @map("reject_reason") // Reason for rejection by Owner
  createdById   String          @map("created_by_id")
  approvedById  String?         @map("approved_by_id")
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  supplier   Supplier @relation(fields: [supplierId], references: [id])
  createdBy  User     @relation("POCreatedBy", fields: [createdById], references: [id])
  approvedBy User?    @relation("POApprovedBy", fields: [approvedById], references: [id])

  items           POItem[]
  products        Product[]
  goodsReceivings GoodsReceiving[]
  stockAlerts     StockAlert[]

  @@index([supplierId])
  @@index([status])
  @@map("purchase_orders")
}

model POItem {
  id             String   @id @default(uuid())
  poId           String   @map("po_id")
  brand          String?
  model          String?
  color          String?
  storage        String?
  category       String?
  accessoryType  String?  @map("accessory_type")
  accessoryBrand String?  @map("accessory_brand")
  quantity       Int
  unitPrice      Decimal  @map("unit_price") @db.Decimal(12, 2)
  receivedQty    Int      @default(0) @map("received_qty")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  purchaseOrder  PurchaseOrder        @relation(fields: [poId], references: [id], onDelete: Cascade)
  receivingItems GoodsReceivingItem[]

  @@index([poId])
  @@map("po_items")
}

model Product {
  id                 String          @id @default(uuid())
  name               String
  brand              String
  model              String
  color              String?
  storage            String?
  imeiSerial         String?         @unique @map("imei_serial")
  serialNumber       String?         @map("serial_number")
  category           ProductCategory
  costPrice          Decimal         @map("cost_price") @db.Decimal(12, 2)
  supplierId         String?         @map("supplier_id")
  poId               String?         @map("po_id")
  branchId           String          @map("branch_id")
  status             ProductStatus   @default(IN_STOCK)
  batteryHealth      Int?            @map("battery_health")
  warrantyExpired    Boolean?        @map("warranty_expired")
  warrantyExpireDate DateTime?       @map("warranty_expire_date")
  hasBox             Boolean?        @map("has_box")
  checklistResults   Json?           @map("checklist_results")
  accessoryType      String?         @map("accessory_type")
  accessoryBrand     String?         @map("accessory_brand")
  inspectionId       String?         @map("inspection_id")
  photos             String[]        @default([])
  stockInDate        DateTime?       @map("stock_in_date")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")
  deletedAt          DateTime?       @map("deleted_at")

  supplier   Supplier?      @relation(fields: [supplierId], references: [id])
  po         PurchaseOrder? @relation(fields: [poId], references: [id])
  branch     Branch         @relation(fields: [branchId], references: [id])
  inspection Inspection?    @relation(fields: [inspectionId], references: [id])

  prices               ProductPrice[]
  contracts            Contract[]
  sales                Sale[]
  repossession         Repossession?
  receivingItem        GoodsReceivingItem?
  branchReceivingItems BranchReceivingItem[]
  stockTransfers       StockTransfer[]
  stockAdjustments     StockAdjustment[]
  stockCountItems      StockCountItem[]
  productPhotos        ProductPhoto?

  @@index([branchId])
  @@index([status])
  @@index([category])
  @@index([brand, model])
  @@index([supplierId])
  @@index([deletedAt])
  @@index([createdAt])
  @@index([branchId, status])
  @@map("products")
}

model ProductPhoto {
  id          String   @id @default(uuid())
  productId   String   @unique @map("product_id")
  front       String?  // ด้านหน้า
  back        String?  // ด้านหลัง
  left        String?  // ข้างซ้าย
  right       String?  // ข้างขวา
  top         String?  // ด้านบน
  bottom      String?  // ด้านล่าง
  isCompleted Boolean  @default(false) @map("is_completed")
  uploadedById String? @map("uploaded_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  uploadedBy User?   @relation("ProductPhotoUploadedBy", fields: [uploadedById], references: [id])

  @@map("product_photos")
}

model ProductPrice {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  label     String // e.g. "ราคาเงินสด", "ราคาผ่อน"
  amount    Decimal  @db.Decimal(12, 2)
  isDefault Boolean  @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@map("product_prices")
}

model PricingTemplate {
  id                         String          @id @default(uuid())
  brand                      String
  model                      String
  storage                    String          @default("")
  category                   ProductCategory
  hasWarranty                Boolean         @default(false) @map("has_warranty") // false = ไม่เกี่ยว/ไม่มีประกัน, true = มีประกัน (มือ 2)
  cashPrice                  Decimal         @map("cash_price") @db.Decimal(12, 2)
  installmentBestchoicePrice Decimal         @map("installment_bestchoice_price") @db.Decimal(12, 2)
  installmentFinancePrice    Decimal         @map("installment_finance_price") @db.Decimal(12, 2)
  isActive                   Boolean         @default(true) @map("is_active")
  createdAt                  DateTime        @default(now()) @map("created_at")
  updatedAt                  DateTime        @updatedAt @map("updated_at")

  @@unique([brand, model, storage, category, hasWarranty])
  @@index([brand, model])
  @@index([category])
  @@map("pricing_templates")
}

model StockTransfer {
  id                   String         @id @default(uuid())
  batchNumber          String?        @map("batch_number") // เลขใบโอน เช่น TRF-2026-03-001
  productId            String         @map("product_id")
  fromBranchId         String         @map("from_branch_id")
  toBranchId           String         @map("to_branch_id")
  transferredBy        String         @map("transferred_by")
  notes                String?
  status               TransferStatus @default(PENDING)
  confirmedById        String?        @map("confirmed_by_id")
  confirmedAt          DateTime?      @map("confirmed_at")
  // IN_TRANSIT fields
  dispatchedById       String?        @map("dispatched_by_id")
  dispatchedAt         DateTime?      @map("dispatched_at")
  trackingNote         String?        @map("tracking_note")
  expectedDeliveryDate DateTime?      @map("expected_delivery_date")
  createdAt            DateTime       @default(now()) @map("created_at")

  product      Product @relation(fields: [productId], references: [id])
  fromBranch   Branch  @relation("TransferFrom", fields: [fromBranchId], references: [id])
  toBranch     Branch  @relation("TransferTo", fields: [toBranchId], references: [id])
  confirmedBy  User?   @relation("TransferConfirmedBy", fields: [confirmedById], references: [id])
  dispatchedBy User?   @relation("TransferDispatchedBy", fields: [dispatchedById], references: [id])

  branchReceiving BranchReceiving?

  @@index([productId])
  @@index([status])
  @@index([fromBranchId])
  @@index([toBranchId])
  @@index([batchNumber])
  @@map("stock_transfers")
}

model GoodsReceiving {
  id           String   @id @default(uuid())
  poId         String   @map("po_id")
  receivedById String   @map("received_by_id")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")

  po         PurchaseOrder        @relation(fields: [poId], references: [id], onDelete: Cascade)
  receivedBy User                 @relation("GoodsReceivedBy", fields: [receivedById], references: [id])
  items      GoodsReceivingItem[]

  @@index([poId])
  @@map("goods_receivings")
}

model GoodsReceivingItem {
  id                 String              @id @default(uuid())
  receivingId        String              @map("receiving_id")
  poItemId           String              @map("po_item_id")
  imeiSerial         String?             @map("imei_serial")
  serialNumber       String?             @map("serial_number")
  photos             String[]            @default([])
  status             ReceivingItemStatus
  rejectReason       String?             @map("reject_reason")
  batteryHealth      Int?                @map("battery_health")
  warrantyExpired    Boolean?            @map("warranty_expired")
  warrantyExpireDate DateTime?           @map("warranty_expire_date")
  hasBox             Boolean?            @map("has_box")
  checklistResults   Json?               @map("checklist_results")
  productId          String?             @unique @map("product_id")
  createdAt          DateTime            @default(now()) @map("created_at")

  receiving GoodsReceiving @relation(fields: [receivingId], references: [id], onDelete: Cascade)
  poItem    POItem         @relation(fields: [poItemId], references: [id])
  product   Product?       @relation(fields: [productId], references: [id])

  @@index([receivingId])
  @@index([poItemId])
  @@map("goods_receiving_items")
}

model StockAdjustment {
  id             String                @id @default(uuid())
  productId      String                @map("product_id")
  branchId       String                @map("branch_id")
  reason         StockAdjustmentReason
  previousStatus ProductStatus         @map("previous_status")
  notes          String?
  photos         String[]              @default([])
  adjustedById   String                @map("adjusted_by_id")
  createdAt      DateTime              @default(now()) @map("created_at")

  product    Product @relation(fields: [productId], references: [id])
  branch     Branch  @relation(fields: [branchId], references: [id])
  adjustedBy User    @relation("StockAdjustedBy", fields: [adjustedById], references: [id])

  @@index([productId])
  @@index([branchId])
  @@index([reason])
  @@index([createdAt])
  @@map("stock_adjustments")
}

// ============================================================
// INSPECTION
// ============================================================

model InspectionTemplate {
  id         String   @id @default(uuid())
  name       String
  deviceType String   @map("device_type") // PHONE, TABLET
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  items       InspectionTemplateItem[]
  inspections Inspection[]

  @@map("inspection_templates")
}

model InspectionTemplateItem {
  id         String              @id @default(uuid())
  templateId String              @map("template_id")
  category   String
  itemName   String              @map("item_name")
  scoreType  InspectionScoreType @map("score_type")
  isRequired Boolean             @default(true) @map("is_required")
  weight     Decimal             @default(1) @db.Decimal(5, 2)
  sortOrder  Int                 @default(0) @map("sort_order")
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")

  template InspectionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  results  InspectionResult[]

  @@index([templateId])
  @@map("inspection_template_items")
}

model Inspection {
  id             String          @id @default(uuid())
  productId      String          @map("product_id")
  templateId     String          @map("template_id")
  inspectorId    String          @map("inspector_id")
  inspectedAt    DateTime?       @map("inspected_at")
  overallGrade   ConditionGrade? @map("overall_grade")
  gradeOverride  ConditionGrade? @map("grade_override")
  overrideReason String?         @map("override_reason")
  photos         String[]        @default([])
  notes          String?
  isCompleted    Boolean         @default(false) @map("is_completed")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  template  InspectionTemplate @relation(fields: [templateId], references: [id])
  inspector User               @relation(fields: [inspectorId], references: [id])
  products  Product[]

  results InspectionResult[]

  @@index([productId])
  @@index([templateId])
  @@index([inspectorId])
  @@map("inspections")
}

model InspectionResult {
  id             String          @id @default(uuid())
  inspectionId   String          @map("inspection_id")
  templateItemId String          @map("template_item_id")
  passFail       Boolean?        @map("pass_fail")
  grade          ConditionGrade?
  score          Decimal?        @db.Decimal(5, 2)
  numberValue    Decimal?        @map("number_value") @db.Decimal(10, 2)
  notes          String?
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  inspection   Inspection             @relation(fields: [inspectionId], references: [id], onDelete: Cascade)
  templateItem InspectionTemplateItem @relation(fields: [templateItemId], references: [id])

  @@index([inspectionId])
  @@map("inspection_results")
}

// ============================================================
// DOCUMENTS & SIGNATURES
// ============================================================

model ContractTemplate {
  id           String   @id @default(uuid())
  name         String
  type         String // e.g. STORE_DIRECT, CREDIT_CARD, EXCHANGE
  contentHtml  String   @map("content_html")
  placeholders String[] @default([])
  blocks       Json?    @default("[]") // Block-based editor content (JSON array)
  settings     Json?    // Template settings (letterhead, margins, font sizes, etc.)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("contract_templates")
}

model EDocument {
  id           String   @id @default(uuid())
  contractId   String   @map("contract_id")
  documentType String   @map("document_type") // CONTRACT, RECEIPT_DOWN, RECEIPT_INSTALLMENT, PAYOFF
  fileUrl      String   @map("file_url")
  fileHash     String   @map("file_hash") // SHA-256
  createdById  String   @map("created_by_id")
  createdAt    DateTime @default(now()) @map("created_at")

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([createdById])
  @@map("e_documents")
}

model Signature {
  id             String     @id @default(uuid())
  contractId     String     @map("contract_id")
  signerType     SignerType @map("signer_type")
  signatureImage String     @map("signature_image") // file URL
  ipAddress      String?    @map("ip_address")
  deviceInfo     String?    @map("device_info")
  signedAt       DateTime   @default(now()) @map("signed_at")

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@map("signatures")
}

model StickerTemplate {
  id           String   @id @default(uuid())
  name         String
  sizeWidthMm  Int      @map("size_width_mm")
  sizeHeightMm Int      @map("size_height_mm")
  layoutConfig Json     @map("layout_config")
  placeholders String[] @default([])
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("sticker_templates")
}

// ============================================================
// OPERATIONS
// ============================================================

model Repossession {
  id              String             @id @default(uuid())
  contractId      String             @unique @map("contract_id")
  productId       String             @unique @map("product_id")
  repossessedDate DateTime           @map("repossessed_date")
  conditionGrade  ConditionGrade     @map("condition_grade")
  appraisalPrice  Decimal            @map("appraisal_price") @db.Decimal(12, 2)
  appraisedById   String             @map("appraised_by_id")
  repairCost      Decimal            @default(0) @map("repair_cost") @db.Decimal(12, 2)
  resellPrice     Decimal?           @map("resell_price") @db.Decimal(12, 2)
  photos          String[]           @default([])
  status          RepossessionStatus @default(REPOSSESSED)
  soldContractId  String?            @map("sold_contract_id")
  notes           String?
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  contract    Contract @relation(fields: [contractId], references: [id])
  product     Product  @relation(fields: [productId], references: [id])
  appraisedBy User     @relation("AppraisedBy", fields: [appraisedById], references: [id])

  @@map("repossessions")
}

// ============================================================
// COMMUNICATION & LOGGING
// ============================================================

model NotificationLog {
  id        String              @id @default(uuid())
  channel   NotificationChannel
  recipient String // phone or LINE user ID
  subject   String?
  message   String
  status    String // SENT, FAILED, PENDING
  relatedId String?             @map("related_id") // contract_id or payment_id
  errorMsg  String?             @map("error_msg")
  sentAt    DateTime?           @map("sent_at")
  createdAt DateTime            @default(now()) @map("created_at")

  @@index([relatedId])
  @@index([channel])
  @@index([createdAt])
  @@index([status, channel])
  @@map("notification_logs")
}

model CallLog {
  id         String   @id @default(uuid())
  contractId String   @map("contract_id")
  callerId   String   @map("caller_id")
  calledAt   DateTime @map("called_at")
  result     String // e.g. ANSWERED, NO_ANSWER, PROMISED, REFUSED
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")

  contract Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  caller   User     @relation(fields: [callerId], references: [id])

  @@index([contractId])
  @@index([callerId])
  @@map("call_logs")
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  action    String // CREATE, UPDATE, DELETE, EXCHANGE, REPOSSESSION, etc.
  entity    String // e.g. contract, payment, product
  entityId  String   @map("entity_id")
  oldValue  Json?    @map("old_value")
  newValue  Json?    @map("new_value")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  duration  Int? // request duration in ms
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([entity, entityId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model SystemConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  label     String? // Thai description
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_config")
}

// ============================================================
// POINT OF SALE
// ============================================================

model Sale {
  id                String         @id @default(uuid())
  saleNumber        String         @unique @map("sale_number")
  saleType          SaleType       @map("sale_type")
  customerId        String         @map("customer_id")
  productId         String         @map("product_id")
  branchId          String         @map("branch_id")
  salespersonId     String         @map("salesperson_id")
  sellingPrice      Decimal        @map("selling_price") @db.Decimal(12, 2)
  discount          Decimal        @default(0) @db.Decimal(12, 2)
  netAmount         Decimal        @map("net_amount") @db.Decimal(12, 2)
  paymentMethod     PaymentMethod? @map("payment_method")
  amountReceived    Decimal?       @map("amount_received") @db.Decimal(12, 2)
  contractId        String?        @unique @map("contract_id")
  financeCompany    String?        @map("finance_company")
  financeRefNumber  String?        @map("finance_ref_number")
  financeAmount     Decimal?       @map("finance_amount") @db.Decimal(12, 2)
  downPaymentAmount Decimal?       @map("down_payment_amount") @db.Decimal(12, 2)
  bundleProductIds  String[]       @default([]) @map("bundle_product_ids")
  notes             String?
  createdAt         DateTime       @default(now()) @map("created_at")

  customer    Customer  @relation(fields: [customerId], references: [id])
  product     Product   @relation(fields: [productId], references: [id])
  branch      Branch    @relation(fields: [branchId], references: [id])
  salesperson User      @relation("SalesSalesperson", fields: [salespersonId], references: [id])
  contract    Contract? @relation(fields: [contractId], references: [id])

  @@index([saleType])
  @@index([branchId])
  @@index([createdAt])
  @@index([customerId])
  @@index([salespersonId])
  @@index([productId])
  @@map("sales")
}

// ============================================================
// INTEREST CONFIG & CONTRACT DOCUMENTS & CREDIT CHECK
// ============================================================

model InterestConfig {
  id                   String   @id @default(uuid())
  name                 String // เช่น "มือ 1", "มือ 2"
  productCategories    String[] @default([]) @map("product_categories")
  interestRate         Decimal  @map("interest_rate") @db.Decimal(5, 4)
  minDownPaymentPct    Decimal  @map("min_down_payment_pct") @db.Decimal(5, 4)
  storeCommissionPct   Decimal  @default(0.10) @map("store_commission_pct") @db.Decimal(5, 4)
  vatPct               Decimal  @default(0.07) @map("vat_pct") @db.Decimal(5, 4)
  maxInstallmentMonths Int      @map("max_installment_months")
  minInstallmentMonths Int      @map("min_installment_months")
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  contracts Contract[]

  @@map("interest_configs")
}

model ContractDocument {
  id           String               @id @default(uuid())
  contractId   String               @map("contract_id")
  documentType ContractDocumentType @map("document_type")
  fileName     String               @map("file_name")
  fileUrl      String               @map("file_url")
  fileSize     Int?                 @map("file_size")
  notes        String?
  uploadedById String               @map("uploaded_by_id")
  createdAt    DateTime             @default(now()) @map("created_at")

  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
  uploadedBy User     @relation("DocumentUploadedBy", fields: [uploadedById], references: [id])

  @@index([contractId])
  @@index([documentType])
  @@map("contract_documents")
}

model CreditCheck {
  id               String            @id @default(uuid())
  contractId       String?           @unique @map("contract_id")
  customerId       String            @map("customer_id")
  status           CreditCheckStatus @default(PENDING)
  bankName         String?           @map("bank_name")
  statementFiles   String[]          @default([]) @map("statement_files")
  statementMonths  Int               @default(3) @map("statement_months")
  aiAnalysis       Json?             @map("ai_analysis")
  aiScore          Int?              @map("ai_score")
  aiSummary        String?           @map("ai_summary")
  aiRecommendation String?           @map("ai_recommendation")
  checkedById      String?           @map("checked_by_id")
  checkedAt        DateTime?         @map("checked_at")
  reviewNotes      String?           @map("review_notes")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  contract  Contract? @relation(fields: [contractId], references: [id])
  customer  Customer  @relation(fields: [customerId], references: [id])
  checkedBy User?     @relation("CreditCheckedBy", fields: [checkedById], references: [id])

  @@index([contractId])
  @@index([customerId])
  @@index([status])
  @@map("credit_checks")
}

// ============================================================
// REORDER POINT & STOCK ALERTS
// ============================================================

model ReorderPoint {
  id              String          @id @default(uuid())
  brand           String
  model           String
  storage         String?
  category        ProductCategory
  branchId        String          @map("branch_id")
  minQuantity     Int             @map("min_quantity") // จำนวนขั้นต่ำก่อนแจ้งเตือน
  reorderQuantity Int             @map("reorder_quantity") // จำนวนที่แนะนำให้สั่ง
  isActive        Boolean         @default(true) @map("is_active")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  branch      Branch       @relation(fields: [branchId], references: [id])
  stockAlerts StockAlert[]

  @@unique([brand, model, storage, category, branchId])
  @@index([branchId])
  @@index([isActive])
  @@map("reorder_points")
}

model StockAlert {
  id              String    @id @default(uuid())
  reorderPointId  String    @map("reorder_point_id")
  brand           String
  model           String
  storage         String?
  category        String
  branchId        String    @map("branch_id")
  currentStock    Int       @map("current_stock")
  minQuantity     Int       @map("min_quantity")
  reorderQuantity Int       @map("reorder_quantity")
  status          String    @default("ACTIVE") // ACTIVE, PO_CREATED, RESOLVED
  poId            String?   @map("po_id") // PO ที่สร้างจาก alert นี้
  resolvedAt      DateTime? @map("resolved_at")
  createdAt       DateTime  @default(now()) @map("created_at")

  reorderPoint ReorderPoint   @relation(fields: [reorderPointId], references: [id])
  branch       Branch         @relation(fields: [branchId], references: [id])
  po           PurchaseOrder? @relation(fields: [poId], references: [id])

  @@index([status])
  @@index([branchId])
  @@index([reorderPointId])
  @@index([createdAt])
  @@map("stock_alerts")
}

// ============================================================
// STOCK COUNT (ตรวจนับสต๊อก)
// ============================================================

model StockCount {
  id          String   @id @default(uuid())
  countNumber String   @unique @map("count_number") // SC-YYYY-MM-NNN
  branchId    String   @map("branch_id")
  countedById String   @map("counted_by_id")
  status      String   @default("DRAFT") // DRAFT, IN_PROGRESS, COMPLETED, CANCELLED
  notes       String?
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  branch    Branch           @relation(fields: [branchId], references: [id])
  countedBy User             @relation("StockCountedBy", fields: [countedById], references: [id])
  items     StockCountItem[]

  @@index([branchId])
  @@index([status])
  @@index([createdAt])
  @@map("stock_counts")
}

model StockCountItem {
  id             String   @id @default(uuid())
  stockCountId   String   @map("stock_count_id")
  productId      String   @map("product_id")
  expectedStatus String   @map("expected_status") // status ในระบบ
  actualFound    Boolean  @default(false) @map("actual_found") // พบสินค้าจริง (default: ยังไม่ตรวจนับ)
  conditionNotes String?  @map("condition_notes")
  scannedImei    String?  @map("scanned_imei") // IMEI ที่สแกนยืนยัน
  createdAt      DateTime @default(now()) @map("created_at")

  stockCount StockCount @relation(fields: [stockCountId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id])

  @@unique([stockCountId, productId])
  @@index([stockCountId])
  @@index([productId])
  @@map("stock_count_items")
}

// ============================================================
// BRANCH RECEIVING (สาขาเช็ครับสินค้า)
// ============================================================

model BranchReceiving {
  id           String   @id @default(uuid())
  transferId   String   @unique @map("transfer_id")
  receivedById String   @map("received_by_id")
  status       String   @default("PENDING") // PENDING, COMPLETED, PARTIAL_REJECT
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")

  transfer   StockTransfer         @relation(fields: [transferId], references: [id])
  receivedBy User                  @relation("BranchReceivedBy", fields: [receivedById], references: [id])
  items      BranchReceivingItem[]

  @@index([transferId])
  @@map("branch_receivings")
}

model BranchReceivingItem {
  id             String   @id @default(uuid())
  receivingId    String   @map("receiving_id")
  productId      String   @map("product_id")
  imeiSerial     String?  @map("imei_serial") // สแกนยืนยัน
  status         String   @default("PASS") // PASS, REJECT
  conditionNotes String?  @map("condition_notes")
  photos         String[] @default([])
  rejectReason   String?  @map("reject_reason")
  createdAt      DateTime @default(now()) @map("created_at")

  receiving BranchReceiving @relation(fields: [receivingId], references: [id], onDelete: Cascade)
  product   Product         @relation(fields: [productId], references: [id])

  @@index([receivingId])
  @@index([productId])
  @@map("branch_receiving_items")
}
