{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      { "include": "modules/documents/templates/**/*.html", "outDir": "dist/src", "watchAssets": true },
      { "include": "modules/contracts/templates/**/*.html", "outDir": "dist/src", "watchAssets": true }
    ]
  }
}
