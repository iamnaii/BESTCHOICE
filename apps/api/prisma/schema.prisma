  customerMessage String                      @map("customer_message") @db.Text
  aiDraft         String?                     @map("ai_draft") @db.Text
  humanEdit       String?                     @map("human_edit") @db.Text
  intent          String?
  quality         Float?
  usedInPrompt    Boolean                     @default(false) @map("used_in_prompt")
