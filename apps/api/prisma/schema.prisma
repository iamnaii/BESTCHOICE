generator client {
  provider = "prisma-client-js"
}

// Cloud SQL (Cloud Run) connection format:
//   postgresql://USER:PASS@localhost/DB?host=/cloudsql/PROJECT:REGION:INSTANCE&connection_limit=10
// Local / TCP connection format:
//   postgresql://USER:PASS@HOST:5432/DB
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

