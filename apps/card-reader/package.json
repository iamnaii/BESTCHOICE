{
  "name": "@installment/card-reader",
  "version": "1.0.0",
  "private": true,
  "description": "Local service for reading Thai National ID Smart Cards via USB card reader",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "bundle": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --external:pcsclite",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "iconv-lite": "^0.6.3"
  },
  "optionalDependencies": {
    "pcsclite": "^1.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "esbuild": "^0.24.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
