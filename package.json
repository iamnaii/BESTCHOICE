{
  "name": "installment-system",
  "version": "1.0.0",
  "private": true,
  "packageManager": "npm@10.9.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\""
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.19",
    "prettier": "^3.2.0",
    "prisma": "^6.19.2",
    "turbo": "^2.4.0"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2"
  },
  "overrides": {
    "multer": "2.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  }
}
